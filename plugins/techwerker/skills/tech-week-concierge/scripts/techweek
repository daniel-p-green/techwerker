class TechWeekError(RuntimeError):
    pass


@dataclass(frozen=True)
class Context:
    city: str
    year: int | None
    base_url: str

    @property
    def calendar_url(self) -> str:
        return f"{self.base_url.rstrip('/')}/{self.city}"


def normalize_city(city: str) -> str:
    key = city.strip().lower()
    return CITY_ALIASES.get(key, key)


def expand_cities(city: str) -> list[str]:
    key = city.strip().lower()
    if key in {"all", "known"}:
        return DEFAULT_CITIES
    if key in {"live", "launched"}:
        return ["nyc", "boston"]
    return [normalize_city(city)]


def location_cluster(city: str, location: str | None) -> str:
    if not location:
        return "TBD"
    normalized = location.lower()
    for needle, cluster in LOCATION_CLUSTERS.get(city, {}).items():
        if needle in normalized:
            return cluster
    return location


def time_slot(time_value: str | None) -> str:
    if not time_value or len(time_value) < 2:
        return "unknown"
    try:
        hour = int(time_value[:2])
    except ValueError:
        return "unknown"
    if hour < 8:
        return "early"
    if hour < 12:
        return "morning"
    if hour < 15:
        return "noon"
    if hour < 17:
        return "afternoon"
    if hour < 21:
        return "evening"
    return "late"


def utc_now() -> str:
    return datetime.now(timezone.utc).replace(microsecond=0).isoformat()


def read_json(path: Path, default: Any) -> Any:
    if not path.exists():
        return default
    with path.open("r", encoding="utf-8") as f:
        return json.load(f)


def write_json(path: Path, data: Any) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    tmp = path.with_name(f".{path.name}.{os.getpid()}.tmp")
    with tmp.open("w", encoding="utf-8") as f:
        json.dump(data, f, indent=2, sort_keys=True)
        f.write("\n")
    tmp.replace(path)


def normalize_form_label(label: str) -> str:
    clean = re.sub(r"[^a-z0-9]+", " ", label.lower())
    return re.sub(r"\s+", " ", clean).strip()


def parse_csv_values(value: str) -> list[str]:
    return [item.strip() for item in value.split(",") if item.strip()]


def parse_filter_values(value: str | None, default: list[str] | None = None) -> list[str]:
    if value is None:
        return list(default or [])
    if value.strip().lower() in {"", "all", "any"}:
        return []
    return parse_csv_values(value)


def format_csv_values(values: list[Any]) -> str:
    return ", ".join(str(value) for value in values if str(value).strip())


def label_has_hint(normalized_label: str, hints: list[str]) -> bool:
    return any(normalize_form_label(hint) in normalized_label for hint in hints)


def generated_answer_class(normalized_label: str, profile_key: str | None = None) -> str | None:
    if profile_key in GENERIC_PROFILE_FIELDS:
        return GENERIC_PROFILE_FIELDS[profile_key]
    for answer_class, config in GENERATED_ANSWER_CLASSES.items():
        if label_has_hint(normalized_label, config["labels"]):
            return answer_class
    return None


def generated_policy(memory: dict[str, Any]) -> dict[str, Any]:
    policy = memory.get("generated_answer_policy") or {}
    approved = sorted({str(value) for value in policy.get("approved_classes", []) if str(value) in GENERATED_ANSWER_CLASSES})
    mode = str(policy.get("mode") or "draft-first")
    return {
        "mode": mode,
        "approvedClasses": approved,
        "autoFillGeneratedWhenApproved": True,
        "updatedAt": policy.get("updatedAt"),
    }


def answer_record(label: str, value: str, source: str = "user", scope: str = "reusable", answer_class: str | None = None) -> dict[str, Any]:
    record = {
        "label": label,
        "value": value,
        "source": source if source in ANSWER_SOURCES else "user",
        "scope": scope,
        "updatedAt": utc_now(),
    }
    if answer_class:
        record["answerClass"] = answer_class
    return record


def build_answer_strategy(memory: dict[str, Any]) -> dict[str, Any]:
    return {
        "sourcePrecedence": ANSWER_SOURCE_PRECEDENCE,
        "generatedPolicy": generated_policy(memory),
        "fieldClasses": {
            "factualProfile": sorted(field for field in FIRST_USE_PROFILE_FIELDS + ["website", "one_liner"] if field not in GENERIC_PROFILE_FIELDS),
            "visiblePrefill": "Use visible non-sensitive values already filled by Partiful account details or previous responses for the current form; do not save unless approved.",
            "savedAnswer": "Event-specific answers override reusable answers.",
            "generatedGeneric": GENERATED_ANSWER_CLASSES,
            "factualUnknown": FACTUAL_ASK_HINTS,
            "sensitiveStop": SENSITIVE_LABEL_HINTS,
        },
        "defaults": {
            "factualPersonalData": "Never invent factual personal data; use saved profile/form memory or ask the user.",
            "visiblePrefill": "If Partiful visibly prefilled a non-sensitive field from account details or previous responses, leave or use that value for the current form without saving it unless the user approves.",
            "generatedGeneric": "Draft from event context and saved preferences; require approval unless the generated answer class is approved.",
            "unknownRequired": "Record needs-user-answer and ask once.",
        },
    }


def prompt_text(label: str, current: Any = "") -> str:
    default = str(current or "")
    suffix = f" [{default}]" if default else ""
    entered = input(f"{label}{suffix}: ").strip()
    return entered if entered else default


def prompt_list(label: str, current: list[Any]) -> list[str]:
    current_text = format_csv_values(current)
    entered = input(f"{label} comma-separated [{current_text}]: ").strip()
    if not entered:
        return [str(item) for item in current if str(item).strip()]
    return parse_csv_values(entered)


def prompt_int(label: str, current: int, minimum: int = 1) -> int:
    entered = input(f"{label} [{current}]: ").strip()
    if not entered:
        return current
    try:
        return max(minimum, int(entered))
    except ValueError:
        print(f"invalid number; keeping {current}", file=sys.stderr)
        return current


def prompt_choice(label: str, choices: list[str], current: str) -> str:
    entered = input(f"{label} ({'/'.join(choices)}) [{current}]: ").strip().lower()
    if not entered:
        return current
    if entered not in choices:
        print(f"invalid choice; keeping {current}", file=sys.stderr)
        return current
    return entered


def fetch_text(url: str) -> str:
    req = urllib.request.Request(
        url,
        headers={
            "User-Agent": "Mozilla/5.0 TechWeekConcierge/0.1",
            "Accept": "text/html,application/xhtml+xml",
        },
    )
    with urllib.request.urlopen(req, timeout=30) as resp:
        return resp.read().decode("utf-8", errors="replace")


def fetch_status(url: str) -> dict[str, Any]:
    req = urllib.request.Request(
        url,
        headers={
            "User-Agent": "Mozilla/5.0 TechWeekConcierge/0.1",
            "Accept": "text/html,application/xhtml+xml",
        },
    )
    try:
        with urllib.request.urlopen(req, timeout=30) as resp:
            resp.read(2048)
            return {"ok": True, "httpStatus": int(resp.status), "finalUrl": resp.geturl()}
    except urllib.error.HTTPError as exc:
        return {"ok": False, "httpStatus": int(exc.code), "finalUrl": exc.geturl(), "error": str(exc)}
    except urllib.error.URLError as exc:
        return {"ok": False, "httpStatus": None, "finalUrl": url, "error": str(exc.reason)}


def fetch_json(url: str) -> Any:
    req = urllib.request.Request(
        url,
        headers={
            "User-Agent": "Mozilla/5.0 TechWeekConcierge/0.1",
            "Accept": "application/json",
        },
    )
    with urllib.request.urlopen(req, timeout=30) as resp:
        return json.loads(resp.read().decode("utf-8"))


def decode_next_flight(html_text: str) -> str:
    decoded_chunks: list[str] = []
    for match in re.finditer(r"self\.__next_f\.push\(\[1,\"(.*?)\"\]\)</script>", html_text, re.S):
        raw = match.group(1)
        try:
            decoded_chunks.append(json.loads(f'"{raw}"'))
        except json.JSONDecodeError:
            decoded_chunks.append(bytes(raw, "utf-8").decode("unicode_escape", errors="replace"))
    if decoded_chunks:
        return html.unescape("".join(decoded_chunks))
    return html.unescape(html_text)


def find_balanced_json_object(text: str, start: int) -> str:
    if start >= len(text) or text[start] != "{":
        raise TechWeekError("internal parser error: JSON object did not start at expected offset")
    depth = 0
    in_string = False
    escape = False
    for idx in range(start, len(text)):
        ch = text[idx]
        if in_string:
            if escape:
                escape = False
            elif ch == "\\":
                escape = True
            elif ch == '"':
                in_string = False
            continue
        if ch == '"':
            in_string = True
        elif ch == "{":
            depth += 1
        elif ch == "}":
            depth -= 1
            if depth == 0:
                return text[start : idx + 1]
    raise TechWeekError("could not find the end of the embedded events JSON")


def extract_events(html_text: str) -> tuple[list[dict[str, Any]], dict[str, Any]]:
    flight = decode_next_flight(html_text)
    marker = '"data":{"pages":'
    pos = flight.find(marker)
    if pos < 0:
        raise TechWeekError("could not find embedded Tech Week event data in page payload")
    data_start = flight.rfind('"data":', 0, pos + len(marker))
    brace_start = flight.find("{", data_start)
    data_json = find_balanced_json_object(flight, brace_start)
    data = json.loads(data_json)

    events: list[dict[str, Any]] = []
    pages = data.get("pages", [])
    for page in pages:
        for event in page.get("results", []):
            events.append(event)
    meta = {
        "page_count": len(pages),
        "reported_total": pages[0].get("total") if pages else len(events),
        "per_page": pages[0].get("perPage") if pages else None,
    }
    if not events:
        raise TechWeekError("embedded payload was found, but contained no events")
    return events, meta


def fetch_calendar_page(ctx: Context, page: int) -> dict[str, Any]:
    input_payload = {
        "0": {
            "city": ctx.city,
            "q": "",
            "featured": False,
            "day": "all",
            "track": [],
            "sponsor": [],
            "theme": [],
            "format": [],
            "location": [],
            "time": [],
            "host": [],
            "sortBy": "time",
            "sortOrder": "asc",
            "cursor": page,
            "direction": "forward",
        }
    }
    encoded = urllib.parse.quote(json.dumps(input_payload, separators=(",", ":")))
    url = f"{ctx.base_url.rstrip('/')}/api/trpc/calendar.events?batch=1&input={encoded}"
    data = fetch_json(url)
    try:
        return data[0]["result"]["data"]
    except (KeyError, IndexError, TypeError) as exc:
        raise TechWeekError(f"unexpected Tech Week API response for page {page}") from exc


def fetch_all_events(ctx: Context, first_page_events: list[dict[str, Any]], meta: dict[str, Any], first_page_only: bool) -> tuple[list[dict[str, Any]], dict[str, Any]]:
    total = int(meta.get("reported_total") or len(first_page_events))
    per_page = int(meta.get("per_page") or len(first_page_events) or 48)
    if first_page_only or total <= len(first_page_events) or per_page <= 0:
        meta["source"] = "hydrated-page"
        return first_page_events, meta

    all_events = list(first_page_events)
    by_id = {str(event.get("id")): event for event in first_page_events}
    page_count = (total + per_page - 1) // per_page
    fetched_pages = 1
    for page in range(2, page_count + 1):
        page_data = fetch_calendar_page(ctx, page)
        fetched_pages += 1
        for event in page_data.get("results", []):
            all_events.append(event)
            by_id[str(event.get("id"))] = event
    merged = list(by_id.values())
    meta.update(
        {
            "page_count": fetched_pages,
            "expected_page_count": page_count,
            "reported_total": total,
            "fetched_raw_count": len(all_events),
            "unique_event_count": len(merged),
            "duplicate_or_overlap_count": len(all_events) - len(merged),
            "per_page": per_page,
            "source": "hydrated-page+trpc",
        }
    )
    return merged, meta


def event_year(events: list[dict[str, Any]], fallback: int | None) -> int:
    if fallback:
        return fallback
    for event in events:
        date = str(event.get("date") or "")
        if re.match(r"^\d{4}-", date):
            return int(date[:4])
    return datetime.now().year


def data_dir(city: str, year: int) -> Path:
    return DATA_ROOT / f"{normalize_city(city)}-{year}"


def stable_event_payload(event: dict[str, Any]) -> dict[str, Any]:
    return {
        "id": event.get("id"),
        "city": event.get("city"),
        "date": event.get("date"),
        "time": event.get("time"),
        "location": event.get("location"),
        "name": event.get("name"),
        "company": event.get("company"),
        "externalHref": event.get("externalHref"),
        "isInviteOnly": event.get("isInviteOnly"),
        "facets": event.get("facets") or {},
    }


def source_hash(payload: dict[str, Any]) -> str:
    raw = json.dumps(payload, sort_keys=True, separators=(",", ":"))
    return hashlib.sha256(raw.encode("utf-8")).hexdigest()[:16]


def normalize_events(raw_events: list[dict[str, Any]], previous: dict[str, Any], now: str, city_slug: str) -> list[dict[str, Any]]:
    prior_by_id = {str(e.get("id")): e for e in previous.get("events", [])}
    normalized = []
    for raw in raw_events:
        payload = stable_event_payload(raw)
        event_id = str(payload["id"])
        prior = prior_by_id.get(event_id, {})
        normalized.append(
            {
                **payload,
                "statusHint": "invite-only-or-missing-link" if not payload.get("externalHref") else "open-link",
                "locationCluster": location_cluster(city_slug, payload.get("location")),
                "timeSlot": time_slot(payload.get("time")),
                "sourceHash": source_hash(payload),
                "firstSeenAt": prior.get("firstSeenAt") or now,
                "lastSeenAt": now,
            }
        )
    normalized.sort(key=lambda e: (str(e.get("date") or ""), str(e.get("time") or ""), str(e.get("name") or "")))
    return normalized


def default_preferences() -> dict[str, Any]:
    return {
        "topics": ["AI", "agents", "founder", "infrastructure", "engineering", "product"],
        "neighborhoods": [],
        "priority_hosts": [],
        "preferred_formats": [],
        "excluded_formats": [],
        "time_windows": ["08:00-20:00"],
        "max_events_per_day": 4,
        "signup_multiplier": 3,
        "target_events_per_slot": 1,
        "cluster_first": True,
        "max_clusters_per_day": 2,
        "avoid_clusters": [],
        "rsvp_mode": "assisted",
    }


def ensure_preferences(root: Path) -> dict[str, Any]:
    path = root / "preferences.json"
    default = default_preferences()
    prefs = read_json(path, default)
    changed = False
    for key, value in default.items():
        if key not in prefs:
            prefs[key] = value
            changed = True
    if changed or not path.exists():
        write_json(path, prefs)
    return prefs


def ensure_profile(root: Path) -> dict[str, Any]:
    path = root / "rsvp-profile.json"
    default = {
        "display_name": "",
        "email": "",
        "phone": "",
        "company": "",
        "title": "",
        "country": "",
        "linkedin": "",
        "website": "",
        "one_liner": "",
        "why_attending": "",
        "comment_template": "Excited to join and meet builders working on AI, product, and founder workflows.",
        "field_aliases": DEFAULT_LABEL_MAPPINGS,
        "custom_answers": {},
        "do_not_store": ["passwords", "one_time_codes", "payment_details", "captcha_solutions", "private_notes"],
    }
    profile = read_json(path, default)
    changed = False
    for key, value in default.items():
        if key not in profile:
            profile[key] = value
            changed = True
    if changed or not path.exists():
        write_json(path, profile)
    return profile


def ensure_form_memory(root: Path) -> dict[str, Any]:
    path = root / "form-memory.json"
    default = {
        "version": 1,
        "label_mappings": DEFAULT_LABEL_MAPPINGS,
        "reusable_answers": {},
        "event_answers": {},
        "generated_answer_policy": {"mode": "draft-first", "approved_classes": []},
        "do_not_store": ["passwords", "one_time_codes", "payment_details", "captcha_solutions", "private_notes"],
        "updatedAt": utc_now(),
    }
    memory = read_json(path, default)
    changed = False
    for key, value in default.items():
        if key not in memory:
            memory[key] = value
            changed = True
    mappings = memory.get("label_mappings") or {}
    for label, profile_key in DEFAULT_LABEL_MAPPINGS.items():
        normalized = normalize_form_label(label)
        if normalized not in mappings:
            mappings[normalized] = profile_key
            changed = True
    if mappings != memory.get("label_mappings"):
        memory["label_mappings"] = mappings
        changed = True
    if changed or not path.exists():
        memory["updatedAt"] = utc_now()
        write_json(path, memory)
    return memory


def load_latest(root: Path) -> dict[str, Any]:
    return read_json(root / "latest.json", {"events": [], "syncedAt": None, "meta": {}})


def fetch_calendar_events(city: str, year: int | None, base_url: str, first_page: bool) -> tuple[Context, int, str, list[dict[str, Any]], dict[str, Any]]:
    ctx = Context(normalize_city(city), year, base_url)
    html_text = fetch_text(ctx.calendar_url)
    raw_events, meta = extract_events(html_text)
    raw_events, meta = fetch_all_events(ctx, raw_events, meta, first_page)
    resolved_year = event_year(raw_events, ctx.year)
    root = data_dir(ctx.city, resolved_year)
    now = utc_now()
    previous = load_latest(root)
    events = normalize_events(raw_events, previous, now, ctx.city)
    return ctx, resolved_year, now, events, meta


def sync_one(city: str, args: argparse.Namespace) -> int:
    ctx, year, now, events, meta = fetch_calendar_events(city, args.year, args.base_url, args.first_page)
    root = data_dir(ctx.city, year)
    latest = {
        "city": ctx.city,
        "year": year,
        "sourceUrl": ctx.calendar_url,
        "syncedAt": now,
        "meta": meta,
        "events": events,
    }
    root.mkdir(parents=True, exist_ok=True)
    ensure_preferences(root)
    ensure_profile(root)
    ensure_form_memory(root)
    write_json(root / "latest.json", latest)
    write_json(root / "snapshots" / f"{now.replace(':', '-')}.json", latest)
    open_links = sum(1 for e in events if e.get("externalHref"))
    review = len(events) - open_links
    print(f"synced {len(events)} events for {ctx.city}-{year}")
    print(f"reported_total={meta.get('reported_total')} pages={meta.get('page_count')} per_page={meta.get('per_page')} source={meta.get('source')}")
    if meta.get("fetched_raw_count") is not None:
        print(f"fetched_raw={meta.get('fetched_raw_count')} unique={meta.get('unique_event_count')} duplicate_or_overlap={meta.get('duplicate_or_overlap_count')}")
    print(f"open_links={open_links} needs_review={review}")
    print(root)
    return 0


def sync(args: argparse.Namespace) -> int:
    failures = 0
    for city in expand_cities(args.city):
        try:
            print(f"== {city} ==") if len(expand_cities(args.city)) > 1 else None
            sync_one(city, args)
        except Exception as exc:
            failures += 1
            print(f"{city}: sync failed or calendar not launched: {exc}", file=sys.stderr)
    return 1 if failures and len(expand_cities(args.city)) == failures else 0


def snapshot_diff(root: Path) -> dict[str, Any]:
    snapshots = sorted((root / "snapshots").glob("*.json"))
    latest = load_latest(root)
    if len(snapshots) < 2:
        return {"ready": False, "latestEvents": len(latest.get("events", [])), "added": [], "changed": [], "removed": []}
    older = read_json(snapshots[-2], {})
    current = read_json(snapshots[-1], {})
    old_by_id = {str(e.get("id")): e for e in older.get("events", [])}
    new_by_id = {str(e.get("id")): e for e in current.get("events", [])}
    added = [e for k, e in new_by_id.items() if k not in old_by_id]
    removed = [e for k, e in old_by_id.items() if k not in new_by_id]
    changed = []
    watched_fields = ["date", "time", "location", "externalHref", "isInviteOnly", "name", "company"]
    for key, event in new_by_id.items():
        old = old_by_id.get(key)
        if not old or old.get("sourceHash") == event.get("sourceHash"):
            continue
        changes = {field: [old.get(field), event.get(field)] for field in watched_fields if old.get(field) != event.get(field)}
        changed.append({"id": event.get("id"), "name": event.get("name"), "changes": changes})
    return {"ready": True, "added": added, "changed": changed, "removed": removed}


def diff_events(args: argparse.Namespace) -> int:
    root = resolve_existing_root(args.city, args.year)
    diff = snapshot_diff(root)
    if not diff.get("ready"):
        print("not enough snapshots to diff yet")
        print(f"latest_events={diff.get('latestEvents', 0)}")
        return 0
    added = diff["added"]
    changed = diff["changed"]
    removed = diff["removed"]
    print(f"added={len(added)} changed={len(changed)} removed={len(removed)}")
    for label, rows in (("ADDED", added[:10]), ("CHANGED", changed[:10]), ("REMOVED", removed[:10])):
        if rows:
            print(f"\n{label}")
            for row in rows:
                if label == "CHANGED":
                    print(f"- {row['id']} {row['name']}: {json.dumps(row['changes'], ensure_ascii=False)}")
                else:
                    print(f"- {row.get('id')} {row.get('date')} {row.get('time')} {row.get('name')}")
    return 0


def text_blob(event: dict[str, Any]) -> str:
    pieces = [
        event.get("name"),
        event.get("company"),
        event.get("location"),
        json.dumps(event.get("facets") or {}, ensure_ascii=False),
    ]
    return " ".join(str(p or "") for p in pieces).lower()


def in_time_window(event_time: str, windows: list[str]) -> bool:
    if not windows:
        return True
    t = event_time[:5]
    for window in windows:
        if "-" not in window:
            continue
        start, end = window.split("-", 1)
        if start <= t <= end:
            return True
    return False


def score_event(event: dict[str, Any], prefs: dict[str, Any]) -> tuple[int, list[str]]:
    blob = text_blob(event)
    score = 0
    reasons: list[str] = []
    for topic in prefs.get("topics", []):
        if str(topic).lower() in blob:
            score += 5
            reasons.append(f"topic:{topic}")
    for neighborhood in prefs.get("neighborhoods", []):
        if str(neighborhood).lower() in str(event.get("location") or "").lower():
            score += 4
            reasons.append(f"location:{neighborhood}")
    for host in prefs.get("priority_hosts", []):
        if str(host).lower() in blob:
            score += 6
            reasons.append(f"host:{host}")
    for preferred in prefs.get("preferred_formats", []):
        if str(preferred).lower() in blob:
            score += 3
            reasons.append(f"format:{preferred}")
    for excluded in prefs.get("excluded_formats", []):
        if str(excluded).lower() in blob:
            score -= 8
            reasons.append(f"excluded:{excluded}")
    if event.get("externalHref"):
        score += 1
    else:
        score -= 2
        reasons.append("needs-review")
    if in_time_window(str(event.get("time") or ""), prefs.get("time_windows", [])):
        score += 2
    else:
        score -= 3
        reasons.append("outside-time-window")
    if event.get("isInviteOnly"):
        score -= 1
        reasons.append("invite-only")
    cluster = event.get("locationCluster") or event.get("location") or "TBD"
    if cluster in set(prefs.get("avoid_clusters", [])):
        score -= 6
        reasons.append(f"avoid-cluster:{cluster}")
    return score, reasons


def scored_events(events: list[dict[str, Any]], prefs: dict[str, Any]) -> list[dict[str, Any]]:
    rows = []
    for event in events:
        score, reasons = score_event(event, prefs)
        rows.append({**event, "score": score, "reasons": reasons})
    rows.sort(
        key=lambda e: (
            str(e.get("date") or ""),
            SLOT_ORDER.get(str(e.get("timeSlot") or ""), 99),
            -int(e.get("score") or 0),
            str(e.get("time") or ""),
            str(e.get("name") or ""),
        )
    )
    return rows


def shortlist(args: argparse.Namespace) -> int:
    root = resolve_existing_root(args.city, args.year)
    latest = load_latest(root)
    prefs = ensure_preferences(root)
    rows = []
    per_day: dict[str, int] = {}
    daily_cap = int(prefs.get("max_events_per_day") or 4)
    for event in latest.get("events", []):
        score, reasons = score_event(event, prefs)
        rows.append({**event, "score": score, "reasons": reasons})
    rows.sort(key=lambda e: (-int(e["score"]), str(e.get("date") or ""), str(e.get("time") or ""), str(e.get("name") or "")))
    selected = []
    for event in rows:
        day = str(event.get("date") or "unknown")
        if per_day.get(day, 0) >= daily_cap:
            continue
        selected.append(event)
        per_day[day] = per_day.get(day, 0) + 1
        if len(selected) >= args.limit:
            break
    write_json(root / "shortlist.json", {"generatedAt": utc_now(), "events": selected})
    for event in selected:
        print(f"{event['score']:>3} {event.get('id')} {event.get('date')} {event.get('time')[:5]} {event.get('name')}")
        if event.get("externalHref"):
            print(f"    {event.get('externalHref')}")
        else:
            print("    needs-review: invite-only-or-missing-link")
    print(f"\nwrote {root / 'shortlist.json'}")
    return 0


def count_values(values: list[str]) -> list[dict[str, Any]]:
    counts: dict[str, int] = {}
    for value in values:
        clean = str(value or "").strip()
        if clean:
            counts[clean] = counts.get(clean, 0) + 1
    return [{"value": value, "count": count} for value, count in sorted(counts.items(), key=lambda item: (-item[1], item[0].lower()))]


def collect_facet_values(value: Any) -> list[str]:
    values: list[str] = []
    if isinstance(value, dict):
        if value.get("label"):
            values.append(str(value["label"]))
        else:
            for nested in value.values():
                values.extend(collect_facet_values(nested))
    elif isinstance(value, list):
        for item in value:
            values.extend(collect_facet_values(item))
    elif value:
        values.append(str(value))
    return values


def event_facet_values(event: dict[str, Any]) -> list[str]:
    facets = event.get("facets") or {}
    values: list[str] = []
    if isinstance(facets, dict):
        for value in facets.values():
            values.extend(collect_facet_values(value))
    elif isinstance(facets, list):
        values.extend(collect_facet_values(facets))
    return values


def text_matches_filter(text: str, needle: str) -> bool:
    clean = needle.strip().lower()
    if not clean:
        return False
    if re.search(r"[^a-z0-9]", clean):
        return clean in text
    return re.search(rf"(?<![a-z0-9]){re.escape(clean)}(?![a-z0-9])", text) is not None


def event_matches_any(event: dict[str, Any], filters: list[str]) -> bool:
    if not filters:
        return True
    facet_text = " ".join(event_facet_values(event)).lower()
    blob = text_blob(event)
    return any(text_matches_filter(facet_text, value) or text_matches_filter(blob, value) for value in filters)


def normalize_query_text(value: str) -> str:
    return re.sub(r"\s+", " ", value.lower().strip())


def cluster_aliases(city: str, cluster: str) -> list[str]:
    city = normalize_city(city)
    cluster = str(cluster or "").strip()
    aliases = [cluster] if cluster else []
    for alias, target in LOCATION_CLUSTERS.get(city, {}).items():
        if target == cluster:
            aliases.append(alias)
    return sorted({alias for alias in aliases if alias}, key=len)


def nearby_clusters(city: str, anchor: str) -> list[str]:
    city = normalize_city(city)
    anchor = str(anchor or "").strip()
    if not anchor:
        return []
    zone = cluster_zone(city, anchor)
    clusters = [anchor]
    for cluster, cluster_zone_value in LOCATION_ZONES.get(city, {}).items():
        if cluster != anchor and cluster_zone_value == zone:
            clusters.append(cluster)
    return clusters


def parse_natural_query(city: str, query: str) -> dict[str, Any]:
    city = normalize_city(city)
    text = normalize_query_text(query)
    dates = []
    for weekday, date_value in WEEKDAY_TO_DATE_2026.items():
        if text_matches_filter(text, weekday):
            dates.append(date_value)
    slots = []
    for phrase, slot in SLOT_KEYWORDS.items():
        if text_matches_filter(text, phrase) and slot not in slots:
            slots.append(slot)
    clusters = []
    for alias, cluster in LOCATION_CLUSTERS.get(city, {}).items():
        if text_matches_filter(text, alias) and cluster not in clusters:
            clusters.append(cluster)
    topic_filters = []
    for phrase, aliases in TOPIC_QUERY_ALIASES.items():
        if text_matches_filter(text, phrase):
            for alias in aliases:
                if alias not in topic_filters:
                    topic_filters.append(alias)
    return {
        "raw": query,
        "dates": dates,
        "timeSlots": slots,
        "locationAnchors": clusters,
        "nearbyClusters": {cluster: nearby_clusters(city, cluster) for cluster in clusters},
        "topicFilters": topic_filters,
    }


def event_matches_query(event: dict[str, Any], city: str, parsed: dict[str, Any]) -> tuple[bool, int, list[str]]:
    score_bonus = 0
    reasons: list[str] = []
    dates = set(parsed.get("dates") or [])
    if dates:
        if str(event.get("date") or "") not in dates:
            return False, 0, []
        score_bonus += 6
        reasons.append(f"date:{event.get('date')}")
    slots = set(parsed.get("timeSlots") or [])
    if slots:
        slot = str(event.get("timeSlot") or "")
        if slot not in slots:
            return False, 0, []
        score_bonus += 5
        reasons.append(f"time:{slot}")
    topics = list(parsed.get("topicFilters") or [])
    if topics and not event_matches_any(event, topics):
        return False, 0, []
    if topics:
        score_bonus += 5
        reasons.append(f"topic:{'/'.join(topics[:3])}")
    anchors = list(parsed.get("locationAnchors") or [])
    if anchors:
        cluster = event_cluster(event)
        if cluster in anchors:
            score_bonus += 7
            reasons.append(f"location:{cluster}")
        elif any(cluster in nearby_clusters(city, anchor) for anchor in anchors):
            score_bonus += 4
            reasons.append(f"nearby:{cluster}")
        else:
            return False, 0, []
    return True, score_bonus, reasons


def ask_events(args: argparse.Namespace) -> int:
    city = normalize_city(args.city)
    root = resolve_existing_root(city, args.year)
    latest = load_latest(root)
    prefs = ensure_preferences(root)
    parsed = parse_natural_query(city, args.query)
    rows = []
    for event in scored_events(latest.get("events", []), prefs):
        if args.open_links_only and not event.get("externalHref"):
            continue
        ok, bonus, query_reasons = event_matches_query(event, city, parsed)
        if not ok:
            continue
        cluster = event_cluster(event)
        anchors = set(parsed.get("locationAnchors") or [])
        relation = commute_relation(city, cluster, anchors)
        rows.append(
            {
                **event,
                "score": int(event.get("score") or 0) + bonus,
                "queryReasons": query_reasons,
                "commuteRelation": relation,
                "locationZone": cluster_zone(city, cluster),
            }
        )
    rows.sort(
        key=lambda event: (
            commute_penalty(str(event.get("commuteRelation") or "unknown")),
            -int(event.get("score") or 0),
            str(event.get("date") or ""),
            SLOT_ORDER.get(str(event.get("timeSlot") or ""), 99),
            str(event.get("time") or ""),
            str(event.get("name") or ""),
        )
    )
    selected = rows[: args.limit]
    output = {
        "generatedAt": utc_now(),
        "city": city,
        "query": parsed,
        "matchedCount": len(rows),
        "events": selected,
        "guidance": {
            "plainEnglish": "Use this for requests like 'find me a cool AI event on Tuesday afternoon near Williamsburg' or any configured city neighborhood alias.",
            "locationAwareness": "Location anchors expand to nearby clusters in the same city zone, then sort same-cluster before nearby options.",
            "userFacing": "Summarize event names, day/time, neighborhood, why it matches, and RSVP/list status without exposing event ids unless debugging.",
        },
    }
    write_json(root / "ask-results.json", output)
    if args.json:
        print(json.dumps(output, indent=2, sort_keys=True))
        return 0
    print(f"# Techwerker Ask: {city}")
    print(f"query={args.query}")
    print(
        "parsed="
        f"dates:{format_csv_values(parsed['dates']) or 'any'} "
        f"time_slots:{format_csv_values(parsed['timeSlots']) or 'any'} "
        f"topics:{format_csv_values(parsed['topicFilters']) or 'any'} "
        f"near:{format_csv_values(parsed['locationAnchors']) or 'any'}"
    )
    if parsed["locationAnchors"]:
        for anchor, clusters in parsed["nearbyClusters"].items():
            print(f"nearby:{anchor} -> {format_csv_values(clusters)}")
    if not selected:
        print("\nno matching events")
        print(f"\nwrote {root / 'ask-results.json'}")
        return 0
    for event in selected:
        url = event.get("externalHref") or "invite-only-or-missing-link"
        print(
            f"- score={event.get('score')} {event.get('id')} {event.get('date')} {str(event.get('time') or '')[:5]} "
            f"[{event.get('timeSlot')}] [{event.get('locationCluster')}] {event.get('commuteRelation')} "
            f"{event.get('name')}\n  {url}"
        )
    print(f"\nmatched={len(rows)} shown={len(selected)}")
    print(f"wrote {root / 'ask-results.json'}")
    return 0


def interests(args: argparse.Namespace) -> int:
    root = resolve_existing_root(args.city, args.year)
    output = build_interest_options(root, args.limit)
    for section in ("facets", "hosts", "clusters", "timeSlots"):
        print(f"\n## {section}")
        for row in output[section][: min(args.limit, 20)]:
            print(f"{row['count']:>4} {row['value']}")
    print(f"\nwrote {root / 'interest-options.json'}")
    return 0


def build_interest_options(root: Path, limit: int = 80) -> dict[str, Any]:
    latest = load_latest(root)
    events = latest.get("events", [])
    output = {
        "generatedAt": utc_now(),
        "city": latest.get("city"),
        "year": latest.get("year"),
        "eventCount": len(events),
        "facets": count_values([value for event in events for value in event_facet_values(event)])[:limit],
        "hosts": count_values([str(event.get("company") or "") for event in events])[:limit],
        "locations": count_values([str(event.get("location") or "") for event in events])[:limit],
        "clusters": count_values([str(event.get("locationCluster") or "") for event in events])[:limit],
        "timeSlots": count_values([str(event.get("timeSlot") or "") for event in events]),
    }
    write_json(root / "interest-options.json", output)
    return output


def portfolio_bucket_key(event: dict[str, Any]) -> str:
    return str(event.get("portfolioBucket") or f"{event.get('date')}:{event.get('timeSlot')}")


def event_cluster(event: dict[str, Any]) -> str:
    return str(event.get("locationCluster") or event.get("location") or "TBD")


def cluster_zone(city: str, cluster: str) -> str:
    return LOCATION_ZONES.get(normalize_city(city), {}).get(cluster, cluster)


def commute_relation(city: str, cluster: str, anchors: set[str]) -> str:
    if not anchors:
        return "anchor"
    if not cluster or cluster == "TBD":
        return "unknown"
    if cluster == "Virtual":
        return "flexible"
    if cluster in anchors:
        return "same-cluster"
    zone = cluster_zone(city, cluster)
    if any(cluster_zone(city, anchor) == zone for anchor in anchors):
        return "nearby"
    return "far"


def commute_penalty(relation: str) -> int:
    return {
        "anchor": 0,
        "same-cluster": 0,
        "flexible": 0,
        "nearby": 1,
        "unknown": 2,
        "far": 4,
    }.get(relation, 2)


def preferred_day_clusters(events: list[dict[str, Any]], city: str, max_clusters_per_day: int) -> dict[str, set[str]]:
    by_day: dict[str, dict[str, int]] = {}
    for event in events:
        cluster = event_cluster(event)
        if cluster in {"", "TBD", "Virtual"}:
            continue
        day = str(event.get("date") or "unknown")
        score = max(0, int(event.get("score") or 0)) + 1
        zone = cluster_zone(city, cluster)
        by_day.setdefault(day, {})
        by_day[day][cluster] = by_day[day].get(cluster, 0) + score
        by_day[day][zone] = by_day[day].get(zone, 0) + score // 2

    anchors: dict[str, set[str]] = {}
    for day, cluster_scores in by_day.items():
        real_clusters = [item for item in cluster_scores.items() if item[0] not in set(LOCATION_ZONES.get(normalize_city(city), {}).values())]
        ordered = sorted(real_clusters, key=lambda item: (-item[1], item[0]))
        anchors[day] = {cluster for cluster, _score in ordered[:max_clusters_per_day]}
    return anchors


def portfolio_coverage(events: list[dict[str, Any]], states: dict[str, Any], prefs: dict[str, Any], city: str, multiplier: int | None = None, target_per_slot: int | None = None) -> dict[str, Any]:
    multiplier = multiplier or int(prefs.get("signup_multiplier") or 3)
    target_per_slot = target_per_slot or int(prefs.get("target_events_per_slot") or 1)
    recommended_attempts = max(1, multiplier * target_per_slot)
    buckets: dict[str, dict[str, Any]] = {}
    for event in events:
        bucket = portfolio_bucket_key(event)
        state = str(states.get(str(event.get("id")), {}).get("state") or "new")
        cluster = event_cluster(event)
        record = buckets.setdefault(
            bucket,
            {
                "bucket": bucket,
                "date": str(event.get("date") or ""),
                "timeSlot": str(event.get("timeSlot") or ""),
                "recommendedAttempts": recommended_attempts,
                "targetEvents": target_per_slot,
                "plannedCount": 0,
                "pendingCount": 0,
                "attemptedCount": 0,
                "securedCount": 0,
                "blockedCount": 0,
                "clusters": {},
            },
        )
        record["plannedCount"] += 1
        record["clusters"][cluster] = record["clusters"].get(cluster, 0) + 1
        if state in ATTEMPTED_STATES:
            record["attemptedCount"] += 1
        elif state in BLOCKED_STATES:
            record["blockedCount"] += 1
        elif state not in DONE_OR_BLOCKED_STATES:
            record["pendingCount"] += 1
        if state in SECURED_STATES:
            record["securedCount"] += 1
    for record in buckets.values():
        record["attemptsShortfall"] = max(0, int(record["recommendedAttempts"]) - int(record["attemptedCount"]))
        record["securedShortfall"] = max(0, int(record["targetEvents"]) - int(record["securedCount"]))
        record["clusterCount"] = len(record["clusters"])
        record["primaryClusters"] = [
            {"cluster": cluster, "count": count, "zone": cluster_zone(city, cluster)}
            for cluster, count in sorted(record["clusters"].items(), key=lambda item: (-item[1], item[0]))
        ]
    ordered = sorted(buckets.values(), key=lambda row: (row["date"], SLOT_ORDER.get(row["timeSlot"], 99), row["bucket"]))
    return {
        "riskModel": "High waitlist/low acceptance: keep several RSVP attempts per date/time slot, then collapse overlapping acceptances later.",
        "locationModel": "Prefer clustered or nearby neighborhoods within a day; avoid creating a route that depends on far cross-city hops.",
        "recommendedAttemptsPerBucket": recommended_attempts,
        "targetEventsPerBucket": target_per_slot,
        "buckets": ordered,
    }


def portfolio(args: argparse.Namespace) -> int:
    root = resolve_existing_root(args.city, args.year)
    latest = load_latest(root)
    prefs = ensure_preferences(root)
    multiplier = args.multiplier or int(prefs.get("signup_multiplier") or 3)
    target_per_slot = args.target_per_slot or int(prefs.get("target_events_per_slot") or 1)
    per_bucket_limit = max(1, multiplier * target_per_slot)
    city = normalize_city(args.city)
    max_clusters_per_day = max(1, int(args.max_clusters_per_day or prefs.get("max_clusters_per_day") or 2))

    scored = scored_events(latest.get("events", []), prefs)
    day_anchor_map = preferred_day_clusters(scored, city, max_clusters_per_day)
    buckets: dict[tuple[str, str], list[dict[str, Any]]] = {}
    for event in scored:
        if args.open_links_only and not event.get("externalHref"):
            continue
        if event.get("timeSlot") in {"early", "late", "unknown"} and not args.include_edge_slots:
            continue
        if not args.include_outside_time_windows and not in_time_window(str(event.get("time") or ""), prefs.get("time_windows", [])):
            continue
        buckets.setdefault((str(event.get("date")), str(event.get("timeSlot"))), []).append(event)

    selected: list[dict[str, Any]] = []
    for key in sorted(buckets, key=lambda k: (k[0], SLOT_ORDER.get(k[1], 99))):
        day, slot = key
        anchors = set(day_anchor_map.get(day) or set())
        bucket = sorted(
            buckets[key],
            key=lambda e: (
                commute_penalty(commute_relation(city, event_cluster(e), anchors)) if prefs.get("cluster_first") else 0,
                -int(e.get("score") or 0),
                str(e.get("time") or ""),
                str(e.get("name") or ""),
            ),
        )
        cluster_counts: dict[str, int] = {}
        picks = []
        for event in bucket:
            cluster = str(event.get("locationCluster") or event.get("location") or "TBD")
            relation = commute_relation(city, cluster, anchors)
            if prefs.get("cluster_first") and relation == "far" and anchors:
                continue
            if prefs.get("cluster_first") and cluster_counts.get(cluster, 0) >= max(1, target_per_slot + 1):
                continue
            picks.append({**event, "commuteRelation": relation, "locationZone": cluster_zone(city, cluster)})
            cluster_counts[cluster] = cluster_counts.get(cluster, 0) + 1
            if len(picks) >= per_bucket_limit:
                break
        if len(picks) < per_bucket_limit and bucket:
            picked_ids = {str(event.get("id")) for event in picks}
            for event in bucket:
                if str(event.get("id")) in picked_ids:
                    continue
                cluster = event_cluster(event)
                relation = commute_relation(city, cluster, anchors)
                picks.append({**event, "commuteRelation": f"{relation}-exception" if relation == "far" else relation, "locationZone": cluster_zone(city, cluster)})
                if len(picks) >= per_bucket_limit:
                    break
        for rank, event in enumerate(picks, 1):
            selected.append({**event, "portfolioRank": rank, "portfolioBucket": f"{day}:{slot}", "portfolioAction": "apply"})

    states = read_json(root / "rsvp-state.json", {})
    coverage = portfolio_coverage(selected, states, prefs, city, multiplier, target_per_slot)

    output = {
        "generatedAt": utc_now(),
        "strategy": {
            "signupMultiplier": multiplier,
            "targetEventsPerSlot": target_per_slot,
            "perBucketLimit": per_bucket_limit,
            "openLinksOnly": args.open_links_only,
            "includeOutsideTimeWindows": args.include_outside_time_windows,
            "clusterFirst": bool(prefs.get("cluster_first")),
            "maxClustersPerDay": max_clusters_per_day,
            "riskModel": "High waitlist/low acceptance: target multiple RSVP attempts per date/time slot, then collapse overlapping acceptances later.",
            "locationModel": "Favor same or nearby location clusters within a day so accepted events can become a realistic route.",
            "dayAnchorClusters": {day: sorted(clusters) for day, clusters in day_anchor_map.items()},
        },
        "coverage": coverage,
        "events": selected,
    }
    write_json(root / "portfolio.json", output)

    current_bucket = None
    for event in selected[: args.limit]:
        bucket = event["portfolioBucket"]
        if bucket != current_bucket:
            print(f"\n## {bucket}")
            current_bucket = bucket
        link_status = "link" if event.get("externalHref") else "needs-review"
        print(
            f"{event['portfolioRank']}. score={event['score']} {event.get('id')} "
            f"{str(event.get('time') or '')[:5]} [{event.get('locationCluster')}] "
            f"{event.get('commuteRelation', 'anchor')} "
            f"{event.get('name')} ({link_status})"
        )
    print("\n## Coverage")
    for bucket in coverage["buckets"][: args.limit]:
        clusters = ", ".join(row["cluster"] for row in bucket["primaryClusters"][:3])
        print(
            f"- {bucket['bucket']}: attempts {bucket['attemptedCount']}/{bucket['recommendedAttempts']} "
            f"secured {bucket['securedCount']}/{bucket['targetEvents']} planned {bucket['plannedCount']} clusters {clusters or 'TBD'}"
        )
    print(f"\nwrote {root / 'portfolio.json'}")
    return 0


def apply_queue(args: argparse.Namespace) -> int:
    root = resolve_existing_root(args.city, args.year)
    queue = pending_apply_queue(root)
    for event in queue[: args.limit]:
        print(
            f"{event.get('id')} {event.get('date')} {str(event.get('time') or '')[:5]} "
            f"[{event.get('locationCluster')}] {event.get('name')}\n  {event.get('externalHref')}"
        )
    print(f"\nqueue={min(len(queue), args.limit)} shown / {len(queue)} pending")
    return 0


def is_partiful_url(url: str | None) -> bool:
    if not url:
        return False
    parsed = urllib.parse.urlparse(url)
    return "partiful.com" in parsed.netloc.lower()


def live_queue(args: argparse.Namespace) -> int:
    city = normalize_city(args.city)
    topic_filters = parse_filter_values(args.topics, ["AI"])
    time_slot_filters = {value.strip().lower() for value in parse_filter_values(args.time_slots, ["noon", "evening"])}
    partiful_only = not args.include_non_partiful

    if args.from_cache:
        root = resolve_existing_root(city, args.year)
        latest = load_latest(root)
        events = latest.get("events", [])
        year = int(latest.get("year") or root.name.rsplit("-", 1)[-1])
        source_url = latest.get("sourceUrl") or f"{args.base_url.rstrip('/')}/{city}"
        meta = latest.get("meta") or {}
    else:
        ctx, year, _now, events, meta = fetch_calendar_events(city, args.year, args.base_url, args.first_page)
        root = data_dir(ctx.city, year)
        source_url = ctx.calendar_url

    root.mkdir(parents=True, exist_ok=True)
    prefs = read_json(root / "preferences.json", default_preferences())
    states = read_json(root / "rsvp-state.json", {})

    matched: list[dict[str, Any]] = []
    for event in scored_events(events, prefs):
        url = event.get("externalHref")
        if not url:
            continue
        if partiful_only and not is_partiful_url(url):
            continue
        if time_slot_filters and str(event.get("timeSlot") or "").lower() not in time_slot_filters:
            continue
        if not event_matches_any(event, topic_filters):
            continue
        state = str(states.get(str(event.get("id")), {}).get("state") or "new")
        if state in LIVE_QUEUE_SKIP_STATES:
            continue
        matched.append({**event, "rsvpState": state})

    matched.sort(
        key=lambda event: (
            -int(event.get("score") or 0),
            str(event.get("date") or ""),
            SLOT_ORDER.get(str(event.get("timeSlot") or ""), 99),
            str(event.get("time") or ""),
            str(event.get("name") or ""),
        )
    )
    selected = [{**event, "liveQueueRank": idx + 1} for idx, event in enumerate(matched[: args.limit])]
    output = {
        "generatedAt": utc_now(),
        "city": city,
        "year": year,
        "sourceUrl": source_url,
        "strategy": {
            "topics": topic_filters,
            "timeSlots": sorted(time_slot_filters),
            "partifulOnly": partiful_only,
            "limit": args.limit,
            "skipStates": sorted(LIVE_QUEUE_SKIP_STATES),
            "source": "latest.json" if args.from_cache else meta.get("source", "live-calendar"),
        },
        "matchedCount": len(matched),
        "events": selected,
    }
    write_json(root / "live-queue.json", output)

    print(f"# Live RSVP Queue: {city}-{year}")
    print(f"source={source_url}")
    print(f"filters=topics:{format_csv_values(topic_filters) or 'any'} time_slots:{format_csv_values(sorted(time_slot_filters)) or 'any'} partiful_only={partiful_only}")
    if not selected:
        print("\nno matching live RSVP targets")
        print(f"\nwrote {root / 'live-queue.json'}")
        return 0

    first = selected[0]
    print("\n## First target")
    print(f"{first.get('id')} {first.get('date')} {str(first.get('time') or '')[:5]} [{first.get('timeSlot')}] [{first.get('locationCluster')}] {first.get('name')}")
    print(f"  {first.get('externalHref')}")

    backups = selected[1:]
    if backups:
        print("\n## Backups")
        for event in backups:
            print(f"{event.get('liveQueueRank')}. score={event.get('score')} {event.get('id')} {event.get('date')} {str(event.get('time') or '')[:5]} [{event.get('timeSlot')}] {event.get('name')}")
            print(f"   {event.get('externalHref')}")
    print(f"\nqueue={len(selected)} shown / {len(matched)} matched")
    print(f"wrote {root / 'live-queue.json'}")
    return 0


def pending_apply_queue(root: Path) -> list[dict[str, Any]]:
    portfolio_data = read_json(root / "portfolio.json", {"events": []})
    states = read_json(root / "rsvp-state.json", {})
    prefs = ensure_preferences(root)
    queue = []
    for event in portfolio_data.get("events", []):
        if not event.get("externalHref"):
            continue
        state = states.get(str(event.get("id")), {}).get("state", "new")
        if state in LIVE_QUEUE_SKIP_STATES:
            continue
        queue.append(event)
    city = str(read_json(root / "latest.json", {}).get("city") or root.name.rsplit("-", 1)[0])
    coverage = portfolio_coverage(portfolio_data.get("events", []), states, prefs, city)
    by_bucket = {row["bucket"]: row for row in coverage["buckets"]}
    queue.sort(
        key=lambda event: (
            -int(by_bucket.get(portfolio_bucket_key(event), {}).get("attemptsShortfall", 0)),
            int(by_bucket.get(portfolio_bucket_key(event), {}).get("attemptedCount", 0)),
            str(event.get("date") or ""),
            SLOT_ORDER.get(str(event.get("timeSlot") or ""), 99),
            commute_penalty(str(event.get("commuteRelation") or "unknown")),
            int(event.get("portfolioRank") or 999),
            -int(event.get("score") or 0),
        )
    )
    return queue


def count_by_state(states: dict[str, Any]) -> dict[str, int]:
    counts = {state: 0 for state in RSVP_STATES}
    for record in states.values():
        state = str(record.get("state") or "new")
        counts[state] = counts.get(state, 0) + 1
    return {state: count for state, count in counts.items() if count}


def missing_profile_fields(profile_data: dict[str, Any]) -> list[str]:
    return [field for field in FIRST_USE_PROFILE_FIELDS if not str(profile_data.get(field) or "").strip()]


def missing_optional_profile_fields(profile_data: dict[str, Any]) -> list[str]:
    return [field for field in OPTIONAL_FIRST_USE_PROFILE_FIELDS if not str(profile_data.get(field) or "").strip()]


def print_profile_summary(profile_data: dict[str, Any]) -> None:
    missing = missing_profile_fields(profile_data)
    optional_missing = missing_optional_profile_fields(profile_data)
    print(f"profile={'ready' if not missing else 'missing ' + ', '.join(missing)}")
    if optional_missing:
        print(f"optional_missing={', '.join(optional_missing)}")


def print_event_line(event: dict[str, Any], prefix: str = "-") -> None:
    print(
        f"{prefix} {event.get('id')} {event.get('date')} {str(event.get('time') or '')[:5]} "
        f"[{event.get('locationCluster')}] {event.get('name')}"
    )


def setup_root(args: argparse.Namespace) -> Path:
    city = normalize_city(args.city)
    try:
        root = resolve_existing_root(city, args.year)
    except TechWeekError:
        if args.no_sync:
            raise
        print(f"no local state for {city}; syncing first")
        sync_one(city, args)
        root = resolve_existing_root(city, args.year)
    if args.sync:
        sync_one(city, args)
        root = resolve_existing_root(city, args.year)
    return root


def write_setup_summary(root: Path, profile_data: dict[str, Any], prefs: dict[str, Any], interest_options: dict[str, Any]) -> Path:
    missing = missing_profile_fields(profile_data)
    top_facets = ", ".join(row["value"] for row in interest_options.get("facets", [])[:10])
    top_hosts = ", ".join(row["value"] for row in interest_options.get("hosts", [])[:10])
    top_clusters = ", ".join(row["value"] for row in interest_options.get("clusters", [])[:10])
    lines = [
        "# Tech Week Setup",
        "",
        f"- State root: {root}",
        f"- Profile: {'ready' if not missing else 'missing ' + ', '.join(missing)}",
        f"- Topics: {format_csv_values(prefs.get('topics', []))}",
        f"- Priority hosts: {format_csv_values(prefs.get('priority_hosts', [])) or '[none]'}",
        f"- Preferred neighborhoods: {format_csv_values(prefs.get('neighborhoods', [])) or '[none]'}",
        f"- Preferred formats: {format_csv_values(prefs.get('preferred_formats', [])) or '[none]'}",
        f"- Avoid clusters: {format_csv_values(prefs.get('avoid_clusters', [])) or '[none]'}",
        f"- Excluded formats: {format_csv_values(prefs.get('excluded_formats', [])) or '[none]'}",
        f"- Time windows: {format_csv_values(prefs.get('time_windows', []))}",
        f"- Signup multiplier: {prefs.get('signup_multiplier')}",
        f"- RSVP mode: {prefs.get('rsvp_mode')}",
        "",
        "## Available Signals",
        "",
        f"- Top facets: {top_facets}",
        f"- Top hosts: {top_hosts}",
        f"- Top clusters: {top_clusters}",
        "",
        "## Next Commands",
        "",
        f"- `techweek cockpit --city {root.name.rsplit('-', 1)[0]}`",
        f"- `techweek portfolio --city {root.name.rsplit('-', 1)[0]}`",
        f"- `techweek apply-queue --city {root.name.rsplit('-', 1)[0]}`",
    ]
    path = root / "setup-summary.md"
    path.write_text("\n".join(lines) + "\n", encoding="utf-8")
    return path


def setup(args: argparse.Namespace) -> int:
    root = setup_root(args)
    profile_data = read_json(root / "rsvp-profile.json", {})
    prefs = read_json(root / "preferences.json", default_preferences())
    ensure_form_memory(root)
    interest_options = build_interest_options(root, args.limit)
    interactive = bool(args.interactive or (sys.stdin.isatty() and not args.no_interactive))

    if interactive:
        print(f"Tech Week setup for {root.name}")
        print("Press Enter to keep an existing value. Do not enter secrets or credentials.")
        if not args.preferences_only:
            for field in PROFILE_FIELDS:
                profile_data[field] = prompt_text(PROFILE_FIELD_LABELS.get(field, field), profile_data.get(field, ""))
            write_json(root / "rsvp-profile.json", profile_data)
        if not args.profile_only:
            print("\nTop facets:", format_csv_values([row["value"] for row in interest_options.get("facets", [])[:12]]))
            print("Top hosts:", format_csv_values([row["value"] for row in interest_options.get("hosts", [])[:12]]))
            print("Top clusters:", format_csv_values([row["value"] for row in interest_options.get("clusters", [])[:12]]))
            prefs["topics"] = prompt_list("Topics to reward", prefs.get("topics", []))
            prefs["priority_hosts"] = prompt_list("Priority hosts", prefs.get("priority_hosts", []))
            prefs["neighborhoods"] = prompt_list("Preferred neighborhoods/location words", prefs.get("neighborhoods", []))
            prefs["preferred_formats"] = prompt_list("Preferred event types/formats", prefs.get("preferred_formats", []))
            prefs["avoid_clusters"] = prompt_list("Avoid clusters", prefs.get("avoid_clusters", []))
            prefs["excluded_formats"] = prompt_list("Excluded formats/words", prefs.get("excluded_formats", []))
            prefs["time_windows"] = prompt_list("Time windows", prefs.get("time_windows", []))
            prefs["signup_multiplier"] = prompt_int("Signup multiplier", int(prefs.get("signup_multiplier") or 3))
            prefs["target_events_per_slot"] = prompt_int("Target events per slot", int(prefs.get("target_events_per_slot") or 1))
            prefs["max_clusters_per_day"] = prompt_int("Max location clusters per day", int(prefs.get("max_clusters_per_day") or 2))
            prefs["rsvp_mode"] = prompt_choice("Default RSVP mode", ["manual", "assisted"], str(prefs.get("rsvp_mode") or "assisted"))
            write_json(root / "preferences.json", prefs)

    summary_path = write_setup_summary(root, profile_data, prefs, interest_options)
    missing = missing_profile_fields(profile_data)
    print(f"setup_root={root}")
    print(f"profile={'ready' if not missing else 'missing ' + ', '.join(missing)}")
    print(f"preferences={root / 'preferences.json'}")
    print(f"profile_path={root / 'rsvp-profile.json'}")
    print(f"form_memory={root / 'form-memory.json'}")
    print(f"interest_options={root / 'interest-options.json'}")
    print(f"summary={summary_path}")
    if not interactive and missing:
        print("\nRun `techweek setup --city {city} --interactive` to fill missing profile fields.".format(city=normalize_city(args.city)))
    print("\nNext:")
    print(f"  techweek cockpit --city {normalize_city(args.city)}")
    print(f"  techweek portfolio --city {normalize_city(args.city)}")
    print(f"  techweek apply-queue --city {normalize_city(args.city)}")
    return 0


def demo_reset(args: argparse.Namespace) -> int:
    root = setup_root(args)
    profile_data = ensure_profile(root)
    prefs = ensure_preferences(root)
    ensure_form_memory(root)

    demo_profile = DEMO_PROFILES[args.persona]
    profile_data.update(demo_profile)
    prefs.update(DEMO_PREFERENCES)
    write_json(root / "rsvp-profile.json", profile_data)
    write_json(root / "preferences.json", prefs)

    if not args.keep_state:
        for filename in ("rsvp-state.json", "live-queue.json", "portfolio.json"):
            path = root / filename
            if path.exists():
                path.unlink()
        answer_sheets = root / "answer-sheets"
        if answer_sheets.exists():
            shutil.rmtree(answer_sheets)

    interest_options = build_interest_options(root, args.limit)
    summary_path = write_setup_summary(root, profile_data, prefs, interest_options)
    print(f"demo_root={root}")
    print(f"profile=demo {demo_profile['display_name']}")
    print(f"persona={args.persona}")
    print(f"preferences={root / 'preferences.json'}")
    print(f"profile_path={root / 'rsvp-profile.json'}")
    print(f"summary={summary_path}")
    print(f"state={'kept' if args.keep_state else 'cleared'}")
    return 0


def cockpit(args: argparse.Namespace) -> int:
    root = resolve_existing_root(args.city, args.year)
    latest = load_latest(root)
    events = latest.get("events", [])
    portfolio_data = read_json(root / "portfolio.json", {"events": []})
    states = read_json(root / "rsvp-state.json", {})
    profile_data = ensure_profile(root)
    form_memory_data = ensure_form_memory(root)
    diff = snapshot_diff(root)
    queue = pending_apply_queue(root)

    open_links = sum(1 for event in events if event.get("externalHref"))
    needs_review = len(events) - open_links
    state_counts = count_by_state(states)
    missing_fields = missing_profile_fields(profile_data)
    reusable_answers = form_memory_data.get("reusable_answers") or {}
    event_answers = form_memory_data.get("event_answers") or {}

    print(f"# Tech Week Cockpit: {latest.get('city')}-{latest.get('year')}")
    print(f"state_root={root}")
    print(f"synced={latest.get('syncedAt')} events={len(events)} open_links={open_links} needs_review={needs_review}")
    print(f"portfolio_targets={len(portfolio_data.get('events', []))} apply_queue_pending={len(queue)}")
    print(f"profile={'missing ' + ', '.join(missing_fields) if missing_fields else 'ready'}")
    print(
        "form_memory="
        f"{len(form_memory_data.get('label_mappings') or {})} mappings, "
        f"{len(reusable_answers)} reusable answers, {sum(len(v) for v in event_answers.values())} event answers"
    )

    if state_counts:
        print("\n## RSVP State")
        for state, count in sorted(state_counts.items(), key=lambda item: (RSVP_STATES.index(item[0]) if item[0] in RSVP_STATES else 99, item[0])):
            print(f"- {state}: {count}")

    if diff.get("ready"):
        print("\n## Recent Calendar Changes")
        print(f"- added={len(diff['added'])} changed={len(diff['changed'])} removed={len(diff['removed'])}")
        for event in diff["added"][: args.limit]:
            print_event_line(event)
    else:
        print("\n## Recent Calendar Changes")
        print(f"- not enough snapshots yet; latest_events={diff.get('latestEvents', 0)}")

    print("\n## Next Apply Queue")
    if queue:
        for event in queue[: args.limit]:
            print_event_line(event)
    else:
        print("- no pending apply targets")

    if portfolio_data.get("events"):
        city = str(latest.get("city") or normalize_city(args.city))
        coverage = portfolio_coverage(portfolio_data.get("events", []), states, ensure_preferences(root), city)
        gaps = [row for row in coverage["buckets"] if row["attemptsShortfall"] or row["securedShortfall"]]
        print("\n## Coverage Gaps")
        if gaps:
            for row in gaps[: args.limit]:
                clusters = ", ".join(cluster["cluster"] for cluster in row["primaryClusters"][:3])
                print(
                    f"- {row['bucket']}: attempts {row['attemptedCount']}/{row['recommendedAttempts']} "
                    f"secured {row['securedCount']}/{row['targetEvents']} clusters {clusters or 'TBD'}"
                )
        else:
            print("- coverage targets met for planned buckets")

    if args.date:
        day_events = [event for event in portfolio_data.get("events", []) if str(event.get("date")) == args.date]
        if day_events:
            print(f"\n## Day Focus: {args.date}")
            day_events.sort(key=lambda e: (SLOT_ORDER.get(str(e.get("timeSlot")), 99), str(e.get("time") or ""), -int(e.get("score") or 0)))
            for event in day_events[: args.limit]:
                state = states.get(str(event.get("id")), {}).get("state", "target")
                print(f"- {state}: {str(event.get('time') or '')[:5]} [{event.get('locationCluster')}] {event.get('name')} id={event.get('id')}")
        else:
            print(f"\n## Day Focus: {args.date}")
            print("- no portfolio targets for this date")
    return 0


def day_plan(args: argparse.Namespace) -> int:
    root = resolve_existing_root(args.city, args.year)
    portfolio_data = read_json(root / "portfolio.json", {"events": []})
    states = read_json(root / "rsvp-state.json", {})
    events = [e for e in portfolio_data.get("events", []) if str(e.get("date")) == args.date]
    if not events:
        raise TechWeekError(f"no portfolio events found for {args.date}; run portfolio first")
    events.sort(key=lambda e: (SLOT_ORDER.get(str(e.get("timeSlot")), 99), str(e.get("time") or ""), -int(e.get("score") or 0)))
    current_slot = None
    previous_cluster = None
    city = normalize_city(args.city)
    for event in events:
        slot = str(event.get("timeSlot") or "unknown")
        if slot != current_slot:
            print(f"\n## {args.date} {slot}")
            current_slot = slot
        cluster = event_cluster(event)
        relation = commute_relation(city, cluster, {previous_cluster} if previous_cluster else set())
        state = states.get(str(event.get("id")), {}).get("state", "target")
        commute_note = f" commute={relation}" if previous_cluster else ""
        print(
            f"- {state}: {str(event.get('time') or '')[:5]} [{event.get('locationCluster')}] "
            f"{event.get('name')} ({event.get('company')}) id={event.get('id')}{commute_note}"
        )
        if state in {"accepted", "applied", "waitlisted", "target", "shortlisted", "opened", "filled", "new"} and cluster not in {"", "TBD", "Virtual"}:
            previous_cluster = cluster
    return 0


def resolve_existing_root(city: str, year: int | None) -> Path:
    city = normalize_city(city)
    if year:
        root = data_dir(city, year)
        if root.exists():
            return root
    matches = sorted(DATA_ROOT.glob(f"{city}-*"))
    if matches:
        return matches[-1]
    raise TechWeekError(f"no local state found for {city}; run sync first")


def find_event(root: Path, event_id: str) -> dict[str, Any]:
    for name in ("latest.json", "live-queue.json", "portfolio.json"):
        data = read_json(root / name, {"events": []})
        for event in data.get("events", []):
            if str(event.get("id")) == str(event_id):
                return event
    raise TechWeekError(f"event id not found: {event_id}")


def event_url(event: dict[str, Any], city: str) -> str:
    return str(event.get("externalHref") or f"{DEFAULT_BASE_URL}/{normalize_city(city)}")


def is_partiful_url(url: str) -> bool:
    host = urllib.parse.urlparse(url).netloc.lower()
    return host == "partiful.com" or host.endswith(".partiful.com")


def set_rsvp_state(root: Path, event_id: str, state: str, note: str | None = None) -> None:
    path = root / "rsvp-state.json"
    data = read_json(path, {})
    record = data.get(str(event_id), {})
    record.update({"state": state, "updatedAt": utc_now()})
    if note:
        record["note"] = note
    data[str(event_id)] = record
    write_json(path, data)


def load_state_record(root: Path, event_id: str) -> tuple[Path, dict[str, Any], dict[str, Any]]:
    path = root / "rsvp-state.json"
    data = read_json(path, {})
    record = data.get(str(event_id), {})
    return path, data, record


def add_missing_field(root: Path, event_id: str, label: str, required: bool, field_type: str, note: str | None) -> None:
    path, data, record = load_state_record(root, event_id)
    normalized = normalize_form_label(label)
    fields = [field for field in record.get("missingFields", []) if field.get("normalizedLabel") != normalized]
    fields.append(
        {
            "label": label,
            "normalizedLabel": normalized,
            "required": required,
            "fieldType": field_type,
            "updatedAt": utc_now(),
        }
    )
    record.update({"state": "needs-user-answer", "missingFields": fields, "updatedAt": utc_now()})
    if note:
        record["note"] = note
    data[str(event_id)] = record
    write_json(path, data)


def clear_missing_field(root: Path, event_id: str, label: str | None) -> int:
    path, data, record = load_state_record(root, event_id)
    fields = record.get("missingFields", [])
    if label:
        normalized = normalize_form_label(label)
        fields = [field for field in fields if field.get("normalizedLabel") != normalized]
    else:
        fields = []
    record["missingFields"] = fields
    record["updatedAt"] = utc_now()
    if not fields and record.get("state") == "needs-user-answer":
        record["state"] = "opened"
        record["note"] = "missing form fields resolved; revisit form before submit"
    data[str(event_id)] = record
    write_json(path, data)
    return len(fields)


def open_event(args: argparse.Namespace) -> int:
    root = resolve_existing_root(args.city, args.year)
    event = find_event(root, args.event_id)
    url = event_url(event, args.city)
    state = "opened" if event.get("externalHref") else "needs-review"
    set_rsvp_state(root, args.event_id, state, "event URL prepared for Browser Use handoff")
    print(url)
    if args.system_browser:
        try:
            subprocess.run(["open", url], check=False)
        except OSError as exc:
            print(f"could not open system browser: {exc}", file=sys.stderr)
    return 0


def rsvp_context(args: argparse.Namespace) -> int:
    root = resolve_existing_root(args.city, args.year)
    event = find_event(root, args.event_id)
    profile_data = ensure_profile(root)
    prefs = ensure_preferences(root)
    form_memory_data = ensure_form_memory(root)
    states = read_json(root / "rsvp-state.json", {})
    state_record = states.get(str(event.get("id")), {})
    missing_required = missing_profile_fields(profile_data)
    missing_optional = missing_optional_profile_fields(profile_data)
    answer_sheet_path = root / "answer-sheets" / f"{event.get('id')}.md"
    url = event_url(event, args.city)
    event_summary = {
        "id": str(event.get("id")),
        "name": event.get("name"),
        "date": event.get("date"),
        "time": event.get("time"),
        "timeSlot": event.get("timeSlot"),
        "company": event.get("company"),
        "location": event.get("location"),
        "locationCluster": event.get("locationCluster"),
        "externalHref": event.get("externalHref"),
        "isPartiful": is_partiful_url(url),
        "isInviteOnly": bool(event.get("isInviteOnly")),
        "statusHint": event.get("statusHint"),
    }
    context = {
        "city": normalize_city(args.city),
        "stateRoot": str(root),
        "eventUrl": url,
        "event": event_summary,
        "profile": {
            "ready": not missing_required,
            "missingRequired": missing_required,
            "missingOptional": missing_optional,
            "fields": {field: profile_data.get(field, "") for field in PROFILE_FIELDS},
            "doNotStore": profile_data.get("do_not_store", []),
            "collectionPolicy": PROFILE_COLLECTION_POLICY,
        },
        "preferences": {
            "rsvpMode": prefs.get("rsvp_mode", "assisted"),
            "topics": prefs.get("topics", []),
            "timeWindows": prefs.get("time_windows", []),
            "preferredFormats": prefs.get("preferred_formats", []),
        },
        "formMemory": {
            "labelMappings": form_memory_data.get("label_mappings") or {},
            "reusableAnswers": form_memory_data.get("reusable_answers") or {},
            "eventAnswers": (form_memory_data.get("event_answers") or {}).get(str(event.get("id")), {}),
            "generatedPolicy": generated_policy(form_memory_data),
            "doNotStore": form_memory_data.get("do_not_store", []),
        },
        "missingFields": state_record.get("missingFields") or [],
        "state": state_record.get("state", "new"),
        "answerSheetPath": str(answer_sheet_path),
        "answerSheetExists": answer_sheet_path.exists(),
        "safety": {
            "defaultMode": "assisted",
            "authorizationPhrases": AUTHORIZATION_PHRASES,
            "stopConditions": STOP_CONDITIONS,
            "finalSubmitPolicy": "After event-specific authorization, click scoped RSVP/list/Continue controls for that selected event until visible confirmation, waitlist, or a stop condition.",
        },
        "rsvpActionPolicy": {
            "requiresEventSpecificAuthorization": True,
            "authorizationPhrases": AUTHORIZATION_PHRASES,
            "authorizedActionLabels": PARTIFUL_AUTHORIZED_ACTION_LABELS,
            "clickThroughSteps": RSVP_CLICK_THROUGH_STEPS,
            "browserTabPolicy": BROWSER_TAB_POLICY,
            "platformPolicy": PLATFORM_POLICY,
            "needsUserSubmitPolicy": RSVP_FINAL_STATE_GUIDANCE["needs-user-submit"],
            "finalStateGuidance": RSVP_FINAL_STATE_GUIDANCE,
        },
        "answerStrategy": build_answer_strategy(form_memory_data),
        "platformPolicy": PLATFORM_POLICY,
        "recommendedToolSequence": TOOL_SEQUENCE,
        "browserUse": {
            "backend": "iab",
            "role": "Navigate to eventUrl, inspect visible page/modal state, fill known fields, use non-sensitive visible prefilled values, avoid naive global clicks when labels repeat, and click scoped authorized RSVP/list actions after event-specific authorization.",
        },
        "computerUse": {
            "role": "Optional fallback only: use for an intentionally selected desktop browser/app when Browser Use cannot complete the in-app Partiful flow; stop for unknown or sensitive fields.",
            "macOnlyFallback": True,
            "browserUseIsPrimary": True,
            "codexAppMayBeBlocked": True,
        },
    }
    if args.json:
        print(json.dumps(context, indent=2, sort_keys=True))
    else:
        print(f"{event_summary['name']}")
        print(f"url={url}")
        print(f"profile={'ready' if context['profile']['ready'] else 'missing ' + ', '.join(missing_required)}")
        print(f"state={context['state']}")
        print(f"answer_sheet={answer_sheet_path}")
        print("action_policy=authorized click-through until visible confirmation or stop condition")
        print("tool_sequence=Browser Use iab -> optional Computer Use fallback -> techweek state")
    return 0


def answer_field_decision(
    root: Path,
    event: dict[str, Any],
    label: str,
    required: bool,
    field_type: str,
    record_missing: bool,
    visible_value: str | None = None,
    visible_source: str = "form",
) -> dict[str, Any]:
    event_id = str(event.get("id"))
    normalized = normalize_form_label(label)
    profile_data = ensure_profile(root)
    prefs = ensure_preferences(root)
    memory = ensure_form_memory(root)
    policy = generated_policy(memory)
    base: dict[str, Any] = {
        "eventId": event_id,
        "eventName": event.get("name"),
        "label": label,
        "normalizedLabel": normalized,
        "required": required,
        "fieldType": field_type,
    }

    if label_has_hint(normalized, SENSITIVE_LABEL_HINTS):
        return {
            **base,
            "action": "stop",
            "fieldClass": "sensitive",
            "reason": "Sensitive or unsafe field. Do not fill, generate, store, or attempt to bypass.",
            "stopConditions": STOP_CONDITIONS,
        }

    visible_value = str(visible_value or "").strip()
    if visible_value:
        mappings = memory.get("label_mappings") or {}
        profile_key = mappings.get(normalized)
        answer_class = generated_answer_class(normalized, profile_key)
        return {
            **base,
            "action": "use_visible_value",
            "fieldClass": "visible_prefill",
            "source": "visible",
            "visibleSource": visible_source,
            "profileKey": profile_key,
            "answerClass": answer_class,
            "value": visible_value,
            "shouldSave": False,
            "recordedMissingField": False,
            "reason": "The active Partiful form already shows a non-sensitive value; use it for this RSVP and do not save it unless the user approves.",
            "suggestedStorage": {"type": "profile" if profile_key else "event-or-reusable-form-memory", "saveOnlyWithUserApproval": True},
        }

    event_answers = (memory.get("event_answers") or {}).get(event_id, {})
    if normalized in event_answers and str(event_answers[normalized].get("value") or "").strip():
        return {
            **base,
            "action": "fill_saved_answer",
            "fieldClass": "saved_answer",
            "source": "form-memory",
            "scope": "event",
            "value": event_answers[normalized].get("value"),
            "record": event_answers[normalized],
        }

    reusable_answers = memory.get("reusable_answers") or {}
    if normalized in reusable_answers and str(reusable_answers[normalized].get("value") or "").strip():
        return {
            **base,
            "action": "fill_saved_answer",
            "fieldClass": "saved_answer",
            "source": "form-memory",
            "scope": "reusable",
            "value": reusable_answers[normalized].get("value"),
            "record": reusable_answers[normalized],
        }

    mappings = memory.get("label_mappings") or {}
    profile_key = mappings.get(normalized)
    answer_class = generated_answer_class(normalized, profile_key)
    if answer_class:
        approved = answer_class in policy["approvedClasses"]
        return {
            **base,
            "action": "draft_generic_answer",
            "fieldClass": "generated_generic",
            "answerClass": answer_class,
            "source": "codex-generated",
            "approvalRequired": not approved,
            "mayAutoFillGenerated": approved,
            "generationPolicy": policy,
            "profileTemplate": profile_data.get(profile_key, "") if profile_key else "",
            "draftContext": {
                "event": {
                    "name": event.get("name"),
                    "company": event.get("company"),
                    "date": event.get("date"),
                    "time": event.get("time"),
                    "location": event.get("location"),
                    "statusHint": event.get("statusHint"),
                },
                "profile": {
                    "company": profile_data.get("company", ""),
                    "title": profile_data.get("title", ""),
                    "oneLiner": profile_data.get("one_liner", ""),
                    "whyAttending": profile_data.get("why_attending", ""),
                    "commentTemplate": profile_data.get("comment_template", ""),
                },
                "preferences": {
                    "topics": prefs.get("topics", []),
                    "preferredFormats": prefs.get("preferred_formats", []),
                    "timeWindows": prefs.get("time_windows", []),
                },
            },
        }

    if profile_key:
        value = str(profile_data.get(profile_key) or "").strip()
        if value:
            return {
                **base,
                "action": "fill_from_profile",
                "fieldClass": "factual_profile",
                "source": "profile",
                "profileKey": profile_key,
                "value": value,
            }
        if required and record_missing:
            add_missing_field(root, event_id, label, True, field_type, f"missing profile field: {profile_key}")
        return {
            **base,
            "action": "ask_user",
            "fieldClass": "missing_profile",
            "source": "user",
            "profileKey": profile_key,
            "recordedMissingField": bool(required and record_missing),
            "suggestedStorage": {"type": "profile", "profileKey": profile_key},
        }

    field_class = "factual_unknown" if label_has_hint(normalized, FACTUAL_ASK_HINTS) else "unknown"
    if required and record_missing:
        add_missing_field(root, event_id, label, True, field_type, "unknown required Partiful answer")
    return {
        **base,
        "action": "ask_user",
        "fieldClass": field_class,
        "source": "user",
        "recordedMissingField": bool(required and record_missing),
        "suggestedStorage": {"type": "event-or-reusable-form-memory"},
    }


def answer_field(args: argparse.Namespace) -> int:
    root = resolve_existing_root(args.city, args.year)
    event = find_event(root, args.event_id)
    decision = answer_field_decision(root, event, args.label, not args.optional, args.field_type, not args.no_record_missing, args.visible_value, args.visible_source)
    if args.json:
        print(json.dumps(decision, indent=2, sort_keys=True))
    else:
        print(f"action={decision['action']}")
        print(f"field_class={decision['fieldClass']}")
        if decision.get("value"):
            print(f"value={decision['value']}")
        if decision.get("approvalRequired") is not None:
            print(f"approval_required={str(decision['approvalRequired']).lower()}")
    return 0


def update_state(args: argparse.Namespace) -> int:
    root = resolve_existing_root(args.city, args.year)
    find_event(root, args.event_id)
    set_rsvp_state(root, args.event_id, args.state, args.note)
    print(f"{args.event_id} -> {args.state}")
    print(root / "rsvp-state.json")
    return 0


def profile(args: argparse.Namespace) -> int:
    root = resolve_existing_root(args.city, args.year)
    data = ensure_profile(root)
    path = root / "rsvp-profile.json"
    if args.profile_command == "path":
        print(path)
    elif args.profile_command == "show":
        print(json.dumps(data, indent=2, sort_keys=True))
    elif args.profile_command == "missing":
        print_profile_summary(data)
    elif args.profile_command == "set":
        data[args.field] = args.value
        write_json(path, data)
        print(f"{args.field}=saved")
        print_profile_summary(data)
        print(path)
    else:
        print(f"initialized {path}")
        print_profile_summary(data)
    return 0


def preferences(args: argparse.Namespace) -> int:
    root = resolve_existing_root(args.city, args.year)
    prefs = ensure_preferences(root)
    path = root / "preferences.json"
    command = args.preferences_command
    if command == "path":
        print(path)
        return 0
    if command == "show":
        print(json.dumps(prefs, indent=2, sort_keys=True))
        return 0
    if command == "set-list":
        prefs[args.field] = parse_csv_values(args.values)
        write_json(path, prefs)
        print(f"{args.field}={format_csv_values(prefs[args.field]) or '[none]'}")
        print(path)
        return 0
    raise TechWeekError(f"unknown preferences command: {command}")


def form_memory(args: argparse.Namespace) -> int:
    root = resolve_existing_root(args.city, args.year)
    memory = ensure_form_memory(root)
    path = root / "form-memory.json"
    command = args.form_memory_command
    if command == "path":
        print(path)
        return 0
    if command == "show":
        print(json.dumps(memory, indent=2, sort_keys=True))
        return 0
    if command == "map":
        label = normalize_form_label(args.label)
        memory.setdefault("label_mappings", {})[label] = args.profile_key
        memory["updatedAt"] = utc_now()
        write_json(path, memory)
        print(f"{label} -> {args.profile_key}")
        print(path)
        return 0
    if command == "remember":
        label = normalize_form_label(args.label)
        answer_class = args.answer_class or generated_answer_class(label)
        record = answer_record(args.label, args.value, args.source, "event" if args.event_id else "reusable", answer_class)
        if args.event_id:
            event_answers = memory.setdefault("event_answers", {})
            event_answers.setdefault(str(args.event_id), {})[label] = record
            print(f"remembered event answer for {args.event_id}: {label}")
        else:
            memory.setdefault("reusable_answers", {})[label] = record
            print(f"remembered reusable answer: {label}")
        memory["updatedAt"] = utc_now()
        write_json(path, memory)
        print(path)
        return 0
    if command == "approve-generated":
        answer_class = args.answer_class
        policy = memory.setdefault("generated_answer_policy", {"mode": "draft-first", "approved_classes": []})
        approved = sorted({str(value) for value in policy.get("approved_classes", []) if str(value) in GENERATED_ANSWER_CLASSES} | {answer_class})
        policy["mode"] = policy.get("mode") or "draft-first"
        policy["approved_classes"] = approved
        policy["updatedAt"] = utc_now()
        memory["updatedAt"] = utc_now()
        write_json(path, memory)
        print(f"approved_generated={answer_class}")
        print(path)
        return 0
    if command == "lookup":
        label = normalize_form_label(args.label)
        result: dict[str, Any] = {"label": label}
        mappings = memory.get("label_mappings") or {}
        if label in mappings:
            result["profile_key"] = mappings[label]
        reusable = memory.get("reusable_answers") or {}
        if label in reusable:
            result["reusable_answer"] = reusable[label]
        if args.event_id:
            event_answer = (memory.get("event_answers") or {}).get(str(args.event_id), {}).get(label)
            if event_answer:
                result["event_answer"] = event_answer
        print(json.dumps(result, indent=2, sort_keys=True))
        return 0
    raise TechWeekError(f"unknown form-memory command: {command}")


def missing_fields(args: argparse.Namespace) -> int:
    root = resolve_existing_root(args.city, args.year)
    command = args.missing_fields_command
    states = read_json(root / "rsvp-state.json", {})

    if command == "show":
        records = states.items()
        if args.event_id:
            find_event(root, args.event_id)
            records = [(str(args.event_id), states.get(str(args.event_id), {}))]
        found = False
        for event_id, record in records:
            fields = record.get("missingFields") or []
            if not fields:
                continue
            found = True
            try:
                event = find_event(root, event_id)
                event_label = event.get("name")
            except TechWeekError:
                event_label = "[event missing from latest sync]"
            print(f"{event_id} {record.get('state', 'needs-user-answer')} {event_label}")
            for field in fields:
                required = "required" if field.get("required", True) else "optional"
                print(f"  - {required} {field.get('fieldType', 'text')}: {field.get('label')}")
        if not found:
            print("no missing form fields")
        return 0

    find_event(root, args.event_id)
    if command == "add":
        add_missing_field(root, args.event_id, args.label, not args.optional, args.field_type, args.note)
        print(f"{args.event_id} -> needs-user-answer")
        print(f"missing_field={args.label}")
        print(root / "rsvp-state.json")
        return 0

    if command == "clear":
        remaining = clear_missing_field(root, args.event_id, args.label)
        print(f"{args.event_id} missing_fields_remaining={remaining}")
        print(root / "rsvp-state.json")
        return 0

    if command == "resolve":
        memory_path = root / "form-memory.json"
        memory = ensure_form_memory(root)
        label = normalize_form_label(args.label)
        answer_class = args.answer_class or generated_answer_class(label)
        record = answer_record(args.label, args.value, args.source, "reusable" if args.reusable else "event", answer_class)
        if args.reusable:
            memory.setdefault("reusable_answers", {})[label] = record
            scope = "reusable"
        else:
            memory.setdefault("event_answers", {}).setdefault(str(args.event_id), {})[label] = record
            scope = "event"
        memory["updatedAt"] = utc_now()
        write_json(memory_path, memory)
        remaining = clear_missing_field(root, args.event_id, args.label)
        print(f"remembered {scope} answer for {args.event_id}: {args.label}")
        print(f"missing_fields_remaining={remaining}")
        print(memory_path)
        return 0

    raise TechWeekError(f"unknown missing-fields command: {command}")


def answer_sheet(args: argparse.Namespace) -> int:
    root = resolve_existing_root(args.city, args.year)
    event = find_event(root, args.event_id)
    profile_data = ensure_profile(root)
    form_memory_data = ensure_form_memory(root)
    state_record = read_json(root / "rsvp-state.json", {}).get(str(event.get("id")), {})
    custom = profile_data.get("custom_answers") or {}
    lines = [
        f"# Partiful Answer Sheet: {event.get('name')}",
        "",
        f"- Event ID: {event.get('id')}",
        f"- Date/time: {event.get('date')} {str(event.get('time') or '')[:5]}",
        f"- Host/company: {event.get('company')}",
        f"- Location: {event.get('location') or 'TBD'}",
        f"- Link: {event.get('externalHref') or 'needs review'}",
        "",
        "## Reusable Fields",
        "",
        f"- Name: {profile_data.get('display_name') or '[fill rsvp-profile.json]'}",
        f"- Email: {profile_data.get('email') or '[fill rsvp-profile.json]'}",
        f"- Phone: {profile_data.get('phone') or '[fill rsvp-profile.json]'}",
        f"- Company: {profile_data.get('company') or '[fill rsvp-profile.json]'}",
        f"- Title: {profile_data.get('title') or '[fill rsvp-profile.json]'}",
        f"- Country: {profile_data.get('country') or '[fill rsvp-profile.json]'}",
        f"- LinkedIn: {profile_data.get('linkedin') or '[fill rsvp-profile.json]'}",
        f"- Website: {profile_data.get('website') or '[fill rsvp-profile.json]'}",
        "",
        "## Suggested Free-Text",
        "",
        profile_data.get("comment_template") or "",
        "",
        "## Custom Answers",
        "",
    ]
    if custom:
        for key, value in custom.items():
            lines.append(f"- {key}: {value}")
    else:
        lines.append("- [add reusable custom answers in rsvp-profile.json if Partiful asks repeated questions]")
    lines.extend(["", "## Form Memory", ""])
    mappings = form_memory_data.get("label_mappings") or {}
    reusable_answers = form_memory_data.get("reusable_answers") or {}
    event_answers = (form_memory_data.get("event_answers") or {}).get(str(event.get("id")), {})
    lines.append(f"- Label mappings: {len(mappings)}")
    if reusable_answers:
        lines.append("- Reusable answers:")
        for record in reusable_answers.values():
            metadata = ", ".join(str(value) for value in [record.get("source"), record.get("answerClass")] if value)
            suffix = f" ({metadata})" if metadata else ""
            lines.append(f"  - {record.get('label')}: {record.get('value')}{suffix}")
    if event_answers:
        lines.append("- Event-specific answers:")
        for record in event_answers.values():
            metadata = ", ".join(str(value) for value in [record.get("source"), record.get("answerClass")] if value)
            suffix = f" ({metadata})" if metadata else ""
            lines.append(f"  - {record.get('label')}: {record.get('value')}{suffix}")
    if not reusable_answers and not event_answers:
        lines.append("- No saved custom form answers yet.")
    policy = generated_policy(form_memory_data)
    lines.extend(
        [
            "",
            "## Generated Answer Policy",
            "",
            f"- Mode: {policy['mode']}",
            f"- Approved classes: {format_csv_values(policy['approvedClasses']) or '[none]'}",
        ]
    )
    missing_fields = state_record.get("missingFields") or []
    lines.extend(["", "## Missing Form Fields", ""])
    if missing_fields:
        for field in missing_fields:
            required = "required" if field.get("required", True) else "optional"
            lines.append(f"- {required} {field.get('fieldType', 'text')}: {field.get('label')}")
    else:
        lines.append("- None recorded. If Partiful asks an unknown required question, record it with `techweek missing-fields add`.")
    output = "\n".join(lines) + "\n"
    if args.write:
        path = root / "answer-sheets" / f"{event.get('id')}.md"
        path.parent.mkdir(parents=True, exist_ok=True)
        path.write_text(output, encoding="utf-8")
        print(path)
    else:
        print(output)
    return 0


def export_events(args: argparse.Namespace) -> int:
    root = resolve_existing_root(args.city, args.year)
    latest = load_latest(root)
    events = latest.get("events", [])
    out_dir = root / "exports"
    out_dir.mkdir(parents=True, exist_ok=True)
    if args.format == "json":
        path = out_dir / "events.json"
        write_json(path, events)
    elif args.format == "csv":
        path = out_dir / "events.csv"
        with path.open("w", newline="", encoding="utf-8") as f:
            writer = csv.DictWriter(f, fieldnames=["id", "date", "time", "timeSlot", "name", "company", "location", "locationCluster", "externalHref", "isInviteOnly", "statusHint"])
            writer.writeheader()
            for event in events:
                writer.writerow({field: event.get(field) for field in writer.fieldnames})
    elif args.format == "ics":
        path = out_dir / "events.ics"
        with path.open("w", encoding="utf-8") as f:
            f.write("BEGIN:VCALENDAR\nVERSION:2.0\nPRODID:-//Tech Week Concierge//EN\n")
            for event in events:
                dt = f"{event.get('date')} {event.get('time') or '00:00:00'}"
                try:
                    start = datetime.strptime(dt, "%Y-%m-%d %H:%M:%S")
                    stamp = start.strftime("%Y%m%dT%H%M%S")
                except ValueError:
                    stamp = str(event.get("date") or "").replace("-", "")
                f.write("BEGIN:VEVENT\n")
                f.write(f"UID:techweek-{event.get('id')}@local\n")
                f.write(f"DTSTART:{stamp}\n")
                f.write(f"SUMMARY:{escape_ics(str(event.get('name') or 'Tech Week event'))}\n")
                f.write(f"LOCATION:{escape_ics(str(event.get('location') or ''))}\n")
                if event.get("externalHref"):
                    f.write(f"URL:{event.get('externalHref')}\n")
                f.write("END:VEVENT\n")
            f.write("END:VCALENDAR\n")
    else:
        path = out_dir / "events.md"
        by_day: dict[str, list[dict[str, Any]]] = {}
        for event in events:
            by_day.setdefault(str(event.get("date") or "unknown"), []).append(event)
        with path.open("w", encoding="utf-8") as f:
            f.write(f"# Tech Week {latest.get('city')} {latest.get('year')}\n\n")
            f.write(f"Synced: {latest.get('syncedAt')}\n\n")
            for day in sorted(by_day):
                f.write(f"## {day}\n\n")
                for event in by_day[day]:
                    time_value = str(event.get("time") or "")[:5]
                    href = event.get("externalHref") or ""
                    suffix = f" - {href}" if href else " - needs review"
                    f.write(f"- {time_value} - {event.get('name')} ({event.get('company')}, {event.get('location')}){suffix}\n")
                f.write("\n")
    print(path)
    return 0


def escape_ics(value: str) -> str:
    return value.replace("\\", "\\\\").replace(",", "\\,").replace(";", "\\;").replace("\n", "\\n")


def local_root_for_city(city: str, year: int | None) -> Path | None:
    city = normalize_city(city)
    if year:
        root = data_dir(city, year)
        return root if root.exists() else None
    matches = sorted(DATA_ROOT.glob(f"{city}-*"))
    return matches[-1] if matches else None


def local_city_summary(city: str, year: int | None) -> dict[str, Any]:
    root = local_root_for_city(city, year)
    if not root:
        return {
            "stateRoot": None,
            "localYear": year,
            "localSyncedAt": None,
            "localSyncAgeSeconds": None,
            "localEventCount": 0,
            "localOpenLinkCount": 0,
            "hasPortfolio": False,
            "hasProfile": False,
        }
    latest = load_latest(root)
    events = latest.get("events", [])
    synced_at = latest.get("syncedAt")
    age_seconds = None
    if synced_at:
        try:
            synced_dt = datetime.fromisoformat(str(synced_at).replace("Z", "+00:00"))
            age_seconds = max(0, int((datetime.now(timezone.utc) - synced_dt).total_seconds()))
        except ValueError:
            age_seconds = None
    return {
        "stateRoot": str(root),
        "localYear": latest.get("year") or year,
        "localSyncedAt": synced_at,
        "localSyncAgeSeconds": age_seconds,
        "localEventCount": len(events),
        "localOpenLinkCount": sum(1 for event in events if event.get("externalHref")),
        "hasPortfolio": (root / "portfolio.json").exists(),
        "hasProfile": (root / "rsvp-profile.json").exists(),
    }


def city_status_row(city: str, args: argparse.Namespace) -> dict[str, Any]:
    city = normalize_city(city)
    ctx = Context(city, args.year, args.base_url)
    local = local_city_summary(city, args.year)
    row: dict[str, Any] = {
        "city": city,
        "calendarUrl": ctx.calendar_url,
        "status": "pending",
        "httpStatus": None,
        "finalUrl": None,
        "liveEventCount": 0,
        "liveOpenLinkCount": 0,
        "message": "",
        **local,
    }
    if args.from_cache:
        if row["localEventCount"]:
            row["status"] = "launched"
            row["message"] = "local calendar cache has events"
        else:
            row["status"] = "pending"
            row["message"] = "no local calendar cache yet"
        return row

    status = fetch_status(ctx.calendar_url)
    row["httpStatus"] = status.get("httpStatus")
    row["finalUrl"] = status.get("finalUrl")
    if row["httpStatus"] == 404:
        row["status"] = "pending"
        row["message"] = "calendar URL returned 404; treat as first-class pending city"
        return row
    if row["httpStatus"] != 200:
        row["status"] = "error"
        row["message"] = status.get("error") or f"unexpected HTTP status {row['httpStatus']}"
        return row
    try:
        _ctx, _year, _now, events, _meta = fetch_calendar_events(city, args.year, args.base_url, args.first_page)
    except Exception as exc:
        row["status"] = "error"
        row["message"] = f"calendar fetched but could not parse events: {exc}"
        return row
    row["status"] = "launched" if events else "pending"
    row["liveEventCount"] = len(events)
    row["liveOpenLinkCount"] = sum(1 for event in events if event.get("externalHref"))
    row["message"] = "calendar launched and parseable" if events else "calendar returned no events"
    return row


def city_status(args: argparse.Namespace) -> int:
    rows = [city_status_row(city, args) for city in expand_cities(args.city)]
    if args.json:
        print(json.dumps({"generatedAt": utc_now(), "cities": rows}, indent=2, sort_keys=True))
        return 0
    for row in rows:
        live = f"live_events={row['liveEventCount']} open_links={row['liveOpenLinkCount']}" if row.get("liveEventCount") else f"http={row.get('httpStatus')}"
        local = f"local_events={row['localEventCount']} local_open_links={row['localOpenLinkCount']} synced={row.get('localSyncedAt') or 'never'}"
        print(f"{row['city']} {row['status']} {row['calendarUrl']} {live} {local}")
        if row.get("message"):
            print(f"  {row['message']}")
    return 0


def onboarding_field(field: str, profile_data: dict[str, Any], required: bool = True) -> dict[str, Any]:
    return {
        "key": field,
        "label": PROFILE_FIELD_LABELS.get(field, field),
        "required": required,
        "currentValuePresent": bool(str(profile_data.get(field) or "").strip()),
        "sourcePolicy": "user or clearly visible Partiful account/form value; ask before saving visible values",
    }


def onboarding_context(args: argparse.Namespace) -> int:
    city = normalize_city(args.city)
    status_args = argparse.Namespace(city=city, year=args.year, base_url=args.base_url, from_cache=args.from_cache, first_page=args.first_page)
    status = city_status_row(city, status_args)
    if status["status"] == "pending" and not status.get("localEventCount"):
        output = {
            "generatedAt": utc_now(),
            "city": city,
            "ready": False,
            "cityStatus": status,
            "userFacingSummary": f"{city} is supported, but its Tech Week calendar is pending. Do not invent events.",
            "nextUserPrompt": "That city is supported, but the public calendar is not live yet. I can watch for it or help with New York or Boston now.",
        }
        if args.json:
            print(json.dumps(output, indent=2, sort_keys=True))
        else:
            print(output["userFacingSummary"])
        return 0

    if args.from_cache:
        root = resolve_existing_root(city, args.year)
    elif args.json:
        with contextlib.redirect_stdout(io.StringIO()):
            root = setup_root(args)
    else:
        root = setup_root(args)
    profile_data = ensure_profile(root)
    prefs = ensure_preferences(root)
    ensure_form_memory(root)
    interest_options = build_interest_options(root, args.limit)
    required_fields = [onboarding_field(field, profile_data, True) for field in FIRST_USE_PROFILE_FIELDS]
    optional_fields = [onboarding_field(field, profile_data, False) for field in OPTIONAL_FIRST_USE_PROFILE_FIELDS]
    missing_required = [field["key"] for field in required_fields if not field["currentValuePresent"]]
    output = {
        "generatedAt": utc_now(),
        "city": city,
        "ready": not missing_required,
        "cityStatus": status,
        "profileCollection": {
            "policy": PROFILE_COLLECTION_POLICY,
            "requiredFields": required_fields,
            "optionalFields": optional_fields,
            "missingRequired": missing_required,
            "missingOptional": [field["key"] for field in optional_fields if not field["currentValuePresent"]],
            "compactBatchPrompt": "I need your reusable RSVP basics once: name, email, phone, company, title, country, and LinkedIn. Optional: one sentence on what you want from Tech Week so I can draft harmless why-attend answers.",
        },
        "preferenceQuestions": {
            "topics": {
                "question": "What topics should I prioritize?",
                "current": prefs.get("topics", []),
                "suggestions": [row["value"] for row in interest_options.get("facets", [])[:20]],
            },
            "neighborhoods": {
                "question": "Which neighborhoods or clusters should I prefer or avoid?",
                "current": prefs.get("neighborhoods", []),
                "suggestions": [row["value"] for row in interest_options.get("clusters", [])[:20]],
            },
            "formats": {
                "question": "Which formats should I prioritize or avoid?",
                "current": prefs.get("preferred_formats", []),
                "suggestions": [row["value"] for row in interest_options.get("facets", [])[:30]],
            },
            "timeWindows": {
                "question": "What start times work best?",
                "current": prefs.get("time_windows", []),
                "presets": {
                    "Morning": "08:00-12:00",
                    "Noon": "12:00-15:00",
                    "Afternoon": "15:00-17:00",
                    "Evening": "17:00-21:00",
                },
            },
        },
        "defaultPlan": {
            "review": "Sync and parse the official calendar privately.",
            "select": "Build an overlap-aware portfolio with several attempts per date/time slot and location clustering.",
            "rsvp": "Use Browser Use iab on official Partiful pages, one active RSVP modal at a time.",
            "forms": "Fill profile, saved, and visible prefilled values automatically; ask only for unknown required answers; draft low-stakes generic answers under policy.",
            "state": "Record applied, waitlisted, cancelled, needs-user-answer, or needs-user-submit before switching tabs.",
        },
        "stopConditions": STOP_CONDITIONS,
    }
    if args.json:
        print(json.dumps(output, indent=2, sort_keys=True))
    else:
        print(f"onboarding={'ready' if output['ready'] else 'missing ' + ', '.join(missing_required)}")
        print(output["profileCollection"]["compactBatchPrompt"])
    return 0


def repo_root() -> Path | None:
    candidates = [Path.cwd(), Path(__file__).resolve()]
    for start in candidates:
        current = start if start.is_dir() else start.parent
        for directory in [current, *current.parents]:
            if (directory / "scripts" / "check.sh").exists() and (directory / "plugins" / "techwerker" / "scripts" / "techweek").exists():
                return directory
    return None


def check_record(name: str, status: str, message: str, details: dict[str, Any] | None = None) -> dict[str, Any]:
    return {"name": name, "status": status, "message": message, "details": details or {}}


def same_file_bytes(left: Path, right: Path) -> bool:
    return left.exists() and right.exists() and left.read_bytes() == right.read_bytes()


def script_sync_check(root: Path | None) -> dict[str, Any]:
    if not root:
        return check_record("script-copy-sync", "warn", "repo root not found")
    script = root / "plugins" / "techwerker" / "scripts" / "techweek"
    bundled = root / "plugins" / "techwerker" / "skills" / "tech-week-concierge" / "scripts" / "techweek"
    ok = same_file_bytes(script, bundled)
    return check_record("script-copy-sync", "pass" if ok else "fail", "repo and bundled skill scripts match" if ok else "repo and bundled skill scripts differ", {"script": str(script), "bundled": str(bundled)})


def installed_parity_check(root: Path | None) -> dict[str, Any]:
    if not root:
        return check_record("installed-cache-parity", "warn", "repo root not found")
    script = root / "plugins" / "techwerker" / "scripts" / "techweek"
    skill = root / "plugins" / "techwerker" / "skills" / "tech-week-concierge" / "SKILL.md"
    targets = [
        Path.home() / ".codex" / "plugins" / "cache" / "techwerker" / "techwerker" / "0.1.0" / "scripts" / "techweek",
        Path.home() / ".codex" / "skills" / "tech-week-concierge" / "scripts" / "techweek",
        Path.home() / ".codex" / "skills" / "tech-week-concierge" / "SKILL.md",
    ]
    details = {}
    failures = []
    for target in targets:
        source = skill if target.name == "SKILL.md" else script
        if not target.exists():
            details[str(target)] = "missing"
            continue
        matches = same_file_bytes(source, target)
        details[str(target)] = "match" if matches else "differs"
        if not matches:
            failures.append(str(target))
    if failures:
        return check_record("installed-cache-parity", "fail", "installed Techwerker copies differ from repo", details)
    if any(value == "missing" for value in details.values()):
        return check_record("installed-cache-parity", "warn", "some installed Techwerker copies are not present", details)
    return check_record("installed-cache-parity", "pass", "installed Techwerker copies match repo", details)


def public_hygiene_check(root: Path | None) -> dict[str, Any]:
    if not root:
        return check_record("public-hygiene", "warn", "repo root not found")
    forbidden = re.compile(r"/Users/danielgreen|gho_|Token:|password=|api[_-]?key|SECRET|PRIVATE KEY")
    stale_submit = re.compile(r"pause before final RSVP|pause before final submission|stop before final submit|Stop before final RSVP")
    paths = [
        root / "README.md",
        root / "SECURITY.md",
        root / "plugins" / "techwerker" / ".codex-plugin" / "plugin.json",
        root / "plugins" / "techwerker" / ".claude-plugin" / "plugin.json",
        root / "plugins" / "techwerker" / "README.md",
        root / "plugins" / "techwerker" / "commands" / "techweek.md",
        root / "plugins" / "techwerker" / "commands" / "techweek-rsvp.md",
        root / "plugins" / "techwerker" / "commands" / "techweek-setup.md",
        root / "plugins" / "techwerker" / "references" / "partiful-rsvp-runbook.md",
        root / "plugins" / "techwerker" / "skills" / "tech-week-concierge" / "SKILL.md",
        root / "docs" / "demo-script.md",
        root / "docs" / "launch-copy.md",
        root / "docs" / "release-evidence.md",
        root / "docs" / "ship-readiness.md",
        root / "docs" / "strategy-confidence.md",
        root / "docs" / "demo-video" / "ASSET-MANIFEST.md",
    ]
    hits = []
    for path in paths:
        if not path.exists():
            continue
        text = path.read_text(encoding="utf-8")
        for idx, line in enumerate(text.splitlines(), 1):
            if forbidden.search(line) or stale_submit.search(line):
                hits.append({"path": str(path), "line": idx, "text": line.strip()[:160]})
    if hits:
        return check_record("public-hygiene", "fail", "public docs contain forbidden or stale release language", {"hits": hits})
    return check_record("public-hygiene", "pass", "public docs avoid local paths, secrets, and stale stop-before-submit language")


