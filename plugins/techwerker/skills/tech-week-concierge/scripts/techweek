def fresh_user_acceptance_check(root: Path | None) -> dict[str, Any]:
    if not root:
        return check_record("fresh-user-acceptance", "warn", "repo root not found")
    script = root / "scripts" / "fresh-user-acceptance.sh"
    if not script.exists():
        return check_record("fresh-user-acceptance", "fail", "fresh-user acceptance script is missing", {"script": str(script)})
    result = subprocess.run([str(script)], cwd=str(root), text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, timeout=60)
    details = {
        "script": str(script),
        "returnCode": result.returncode,
        "stdout": result.stdout.strip().splitlines()[-5:],
        "stderr": result.stderr.strip().splitlines()[-5:],
    }
    if result.returncode != 0:
        return check_record("fresh-user-acceptance", "fail", "fresh-user acceptance failed from empty HOME", details)
    return check_record("fresh-user-acceptance", "pass", "fresh-user setup, planning, RSVP context, and answer strategy pass from empty HOME", details)


def portfolio_sanity_check(city: str, year: int | None) -> dict[str, Any]:
    city = normalize_city(city)
    root = local_root_for_city(city, year)
    if not root or not (root / "portfolio.json").exists():
        return check_record(f"portfolio-sanity:{city}", "warn", "no local portfolio to inspect")
    data = read_json(root / "portfolio.json", {})
    events = data.get("events") or []
    coverage = (data.get("coverage") or {}).get("buckets") or []
    strategy = data.get("strategy") or {}
    leaks = [
        {"id": event.get("id"), "time": event.get("time"), "bucket": event.get("portfolioBucket")}
        for event in events
        if not strategy.get("includeOutsideTimeWindows") and not in_time_window(str(event.get("time") or ""), ensure_preferences(root).get("time_windows", []))
    ]
    missing_commute = [event.get("id") for event in events if "commuteRelation" not in event or "locationZone" not in event]
    far_exceptions = [event.get("id") for event in events if str(event.get("commuteRelation") or "").startswith("far")]
    details = {
        "eventCount": len(events),
        "coverageBucketCount": len(coverage),
        "outsideTimeWindowLeaks": leaks[:10],
        "missingCommuteMetadata": missing_commute[:10],
        "farCommuteExceptions": far_exceptions[:10],
    }
    if leaks or missing_commute or not coverage:
        return check_record(f"portfolio-sanity:{city}", "fail", "portfolio violates time-window, coverage, or commute metadata expectations", details)
    return check_record(f"portfolio-sanity:{city}", "pass", "portfolio has hard time-window filtering, coverage buckets, and commute metadata", details)


def rsvp_context_sanity_check(city: str, year: int | None) -> dict[str, Any]:
    city = normalize_city(city)
    root = local_root_for_city(city, year)
    if not root:
        return check_record(f"rsvp-context-sanity:{city}", "warn", "no local state to inspect")
    for source in ("live-queue.json", "portfolio.json", "latest.json"):
        data = read_json(root / source, {"events": []})
        for event in data.get("events", []):
            url = event_url(event, city)
            if not is_partiful_url(url):
                continue
            memory = ensure_form_memory(root)
            details = {
                "eventId": str(event.get("id")),
                "eventUrl": url,
                "answerStrategyMode": build_answer_strategy(memory)["generatedPolicy"]["mode"],
                "authorizedLabels": PARTIFUL_AUTHORIZED_ACTION_LABELS,
                "browserTabMode": BROWSER_TAB_POLICY["mode"],
                "platformPolicy": PLATFORM_POLICY,
            }
            if "Mac-first" not in PLATFORM_POLICY["liveRsvp"] or "Browser Use iab" not in PLATFORM_POLICY["primaryLiveTool"]:
                return check_record(f"rsvp-context-sanity:{city}", "fail", "RSVP context is missing Mac-first Browser Use platform policy", details)
            return check_record(f"rsvp-context-sanity:{city}", "pass", "Partiful event has release-grade RSVP policy context", details)
    return check_record(f"rsvp-context-sanity:{city}", "warn", "no local Partiful event found for RSVP-context inspection")


def plain_ask_sanity_check(city: str, year: int | None) -> dict[str, Any]:
    city = normalize_city(city)
    sample_queries = {
        "nyc": "find me a cool AI event on Tuesday afternoon near Flatiron",
        "boston": "find me a cool AI event on Tuesday afternoon near Cambridge",
        "san-francisco": "find me a cool AI event on Tuesday afternoon near SoMa",
    }
    parsed = parse_natural_query(city, sample_queries.get(city, "find me a cool AI event on Tuesday afternoon"))
    details = {
        "query": parsed["raw"],
        "dates": parsed["dates"],
        "timeSlots": parsed["timeSlots"],
        "locationAnchors": parsed["locationAnchors"],
        "nearbyClusters": parsed["nearbyClusters"],
        "topicFilters": parsed["topicFilters"],
    }
    alias_failures = []
    for alias, expected_cluster in LOCATION_CLUSTERS.get(city, {}).items():
        alias_parsed = parse_natural_query(city, f"find me an AI event on Tuesday afternoon near {alias}")
        if expected_cluster not in alias_parsed["locationAnchors"]:
            alias_failures.append({"alias": alias, "expected": expected_cluster, "actual": alias_parsed["locationAnchors"]})
        if alias_parsed["timeSlots"] != ["afternoon"]:
            alias_failures.append({"alias": alias, "expectedTimeSlots": ["afternoon"], "actualTimeSlots": alias_parsed["timeSlots"]})
    details["aliasCoverageCount"] = len(LOCATION_CLUSTERS.get(city, {}))
    details["aliasFailures"] = alias_failures[:10]
    if parsed["dates"] != ["2026-06-02"] or parsed["timeSlots"] != ["afternoon"] or "AI" not in parsed["topicFilters"]:
        return check_record(f"plain-ask-sanity:{city}", "fail", "plain-English date/time/topic parsing is not reliable", details)
    if alias_failures:
        return check_record(f"plain-ask-sanity:{city}", "fail", "one or more configured neighborhood aliases did not parse correctly", details)
    if city == "nyc" and "Chelsea/West Side" not in parsed["nearbyClusters"].get("Flatiron/NoMad", []):
        return check_record(f"plain-ask-sanity:{city}", "fail", "NYC nearby-cluster expansion is incomplete", details)
    return check_record(f"plain-ask-sanity:{city}", "pass", "plain-English event requests map all configured neighborhood aliases to date/time/topic/location constraints", details)


def onboarding_sanity_check(city: str, year: int | None) -> dict[str, Any]:
    city = normalize_city(city)
    root = local_root_for_city(city, year)
    if not root:
        return check_record(f"onboarding-sanity:{city}", "warn", "no local state to inspect")
    profile_data = ensure_profile(root)
    prefs = ensure_preferences(root)
    required = [onboarding_field(field, profile_data, True) for field in FIRST_USE_PROFILE_FIELDS]
    details = {
        "requiredFieldCount": len(required),
        "missingRequired": [field["key"] for field in required if not field["currentValuePresent"]],
        "timeWindows": prefs.get("time_windows", []),
        "visiblePrefillPolicy": build_answer_strategy(read_json(root / "form-memory.json", {}))["defaults"]["visiblePrefill"],
    }
    if len(required) != len(FIRST_USE_PROFILE_FIELDS) or not details["timeWindows"]:
        return check_record(f"onboarding-sanity:{city}", "fail", "first-run context is missing profile or time-window basics", details)
    return check_record(f"onboarding-sanity:{city}", "pass", "first-run context can collect profile once and avoid visible-value retyping", details)


def city_status_release_check(args: argparse.Namespace) -> dict[str, Any]:
    rows = [city_status_row(city, args) for city in expand_cities(args.city)]
    failing = [row for row in rows if row["status"] == "error"]
    unknown = [row for row in rows if row["city"] != "san-francisco" and row["status"] == "pending"]
    if failing or (unknown and not args.from_cache):
        return check_record("city-status", "fail", "one or more release cities failed live/pending classification", {"cities": rows})
    if unknown:
        return check_record("city-status", "warn", "one or more non-SF cities have no local cache in skip-live mode", {"cities": rows})
    return check_record("city-status", "pass", "NYC/Boston are launchable when available and San Francisco can be pending", {"cities": rows})


def release_check(args: argparse.Namespace) -> int:
    root = repo_root()
    checks = [
        script_sync_check(root),
        city_status_release_check(args),
        public_hygiene_check(root),
        release_artifact_check(root),
        fresh_user_acceptance_check(root),
        installed_parity_check(root),
    ]
    for city in expand_cities(args.city):
        checks.append(onboarding_sanity_check(city, args.year))
        checks.append(plain_ask_sanity_check(city, args.year))
        checks.append(portfolio_sanity_check(city, args.year))
        checks.append(rsvp_context_sanity_check(city, args.year))
    summary = {"pass": 0, "warn": 0, "fail": 0}
    for check in checks:
        summary[check["status"]] = summary.get(check["status"], 0) + 1
    output = {
        "generatedAt": utc_now(),
        "ok": summary.get("fail", 0) == 0,
        "summary": summary,
        "checks": checks,
    }
    if args.json:
        print(json.dumps(output, indent=2, sort_keys=True))
    else:
        for check in checks:
            print(f"{check['status'].upper()} {check['name']}: {check['message']}")
        print(f"summary pass={summary.get('pass', 0)} warn={summary.get('warn', 0)} fail={summary.get('fail', 0)}")
    return 0 if output["ok"] else 1


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(prog="techweek")
    common = argparse.ArgumentParser(add_help=False)
    common.add_argument("--city", default="nyc", help="City slug or alias. Use all/known for NYC, Boston, and pending SF; live/launched for currently live cities.")
    common.add_argument("--year", type=int)
    common.add_argument("--base-url", default=DEFAULT_BASE_URL)
    sub = parser.add_subparsers(dest="command", required=True)

    setup_parser = sub.add_parser("setup", parents=[common])
    setup_parser.add_argument("--interactive", action="store_true", help="Prompt for profile and preference values.")
    setup_parser.add_argument("--no-interactive", action="store_true", help="Never prompt, even from a TTY.")
    setup_parser.add_argument("--sync", action="store_true", help="Refresh the city calendar before setup.")
    setup_parser.add_argument("--no-sync", action="store_true", help="Do not sync if local state is missing.")
    setup_parser.add_argument("--first-page", action="store_true", help="When syncing, only parse the server-embedded first page.")
    setup_parser.add_argument("--profile-only", action="store_true", help="Only prompt for profile fields in interactive mode.")
    setup_parser.add_argument("--preferences-only", action="store_true", help="Only prompt for preferences in interactive mode.")
    setup_parser.add_argument("--limit", type=int, default=80, help="Interest options to retain.")
    setup_parser.set_defaults(func=setup)

    demo_reset_parser = sub.add_parser("demo-reset", parents=[common], help="Seed safe demo profile/preferences and clear local RSVP state.")
    demo_reset_parser.add_argument("--sync", action="store_true", help="Refresh the city calendar before seeding demo values.")
    demo_reset_parser.add_argument("--no-sync", action="store_true", help="Do not sync if local state is missing.")
    demo_reset_parser.add_argument("--first-page", action="store_true", help="When syncing, only parse the server-embedded first page.")
    demo_reset_parser.add_argument("--keep-state", action="store_true", help="Keep RSVP queue/state files instead of clearing them.")
    demo_reset_parser.add_argument("--persona", choices=sorted(DEMO_PROFILES), default="justin", help="Safe sample profile to seed for recording prep.")
    demo_reset_parser.add_argument("--limit", type=int, default=80, help="Interest options to retain.")
    demo_reset_parser.set_defaults(func=demo_reset)

    cockpit_parser = sub.add_parser("cockpit", parents=[common])
    cockpit_parser.add_argument("--date", help="Optional day focus in YYYY-MM-DD format.")
    cockpit_parser.add_argument("--limit", type=int, default=8)
    cockpit_parser.set_defaults(func=cockpit)

    sync_parser = sub.add_parser("sync", parents=[common])
    sync_parser.add_argument("--first-page", action="store_true", help="Only parse the server-embedded first page.")
    sync_parser.set_defaults(func=sync)
    sub.add_parser("diff", parents=[common]).set_defaults(func=diff_events)

    city_status_parser = sub.add_parser("city-status", parents=[common], help="Report public launch/pending/error status for known Tech Week city calendars.")
    city_status_parser.add_argument("--json", action="store_true")
    city_status_parser.add_argument("--from-cache", action="store_true", help="Do not fetch live calendars; classify from local latest.json only.")
    city_status_parser.add_argument("--first-page", action="store_true", help="When fetching live, only parse the server-embedded first page.")
    city_status_parser.set_defaults(func=city_status)

    onboarding_context_parser = sub.add_parser("onboarding-context", parents=[common], help="Emit agent-facing first-run profile, preference, and city readiness context.")
    onboarding_context_parser.add_argument("--json", action="store_true")
    onboarding_context_parser.add_argument("--from-cache", action="store_true", help="Do not fetch live calendars; use existing latest.json only.")
    onboarding_context_parser.add_argument("--sync", action="store_true", help="Refresh the city calendar before emitting context.")
    onboarding_context_parser.add_argument("--no-sync", action="store_true", help="Do not sync if local state is missing.")
    onboarding_context_parser.add_argument("--first-page", action="store_true", help="When syncing, only parse the server-embedded first page.")
    onboarding_context_parser.add_argument("--limit", type=int, default=80, help="Interest options to retain.")
    onboarding_context_parser.set_defaults(func=onboarding_context)

    release_check_parser = sub.add_parser("release-check", parents=[common], help="Run the public-readiness gate without touching RSVP state.")
    release_check_parser.add_argument("--json", action="store_true")
    release_check_parser.add_argument("--skip-live", dest="from_cache", action="store_true", help="Do not fetch live calendars; use local fixtures/cache for city status.")
    release_check_parser.add_argument("--first-page", action="store_true", help="When fetching live, only parse the server-embedded first page.")
    release_check_parser.set_defaults(func=release_check)

    shortlist_parser = sub.add_parser("shortlist", parents=[common])
    shortlist_parser.add_argument("--limit", type=int, default=20)
    shortlist_parser.set_defaults(func=shortlist)

    ask_parser = sub.add_parser("ask", parents=[common], help="Translate a plain-English event request into city/date/time/topic/location-aware matches.")
    ask_parser.add_argument("query")
    ask_parser.add_argument("--limit", type=int, default=5)
    ask_parser.add_argument("--json", action="store_true")
    ask_parser.add_argument("--open-links-only", action="store_true", default=True)
    ask_parser.add_argument("--include-missing-links", dest="open_links_only", action="store_false")
    ask_parser.set_defaults(func=ask_events)

    interests_parser = sub.add_parser("interests", parents=[common])
    interests_parser.add_argument("--limit", type=int, default=80)
    interests_parser.set_defaults(func=interests)

    portfolio_parser = sub.add_parser("portfolio", parents=[common])
    portfolio_parser.add_argument("--multiplier", type=int, help="Oversignup multiplier per intended slot.")
    portfolio_parser.add_argument("--target-per-slot", type=int, help="Intended final attended events per day/time slot.")
    portfolio_parser.add_argument("--max-clusters-per-day", type=int, help="Maximum location clusters to plan around per day.")
    portfolio_parser.add_argument("--limit", type=int, default=80)
    portfolio_parser.add_argument("--open-links-only", action="store_true", default=True)
    portfolio_parser.add_argument("--include-missing-links", dest="open_links_only", action="store_false")
    portfolio_parser.add_argument("--include-edge-slots", action="store_true")
    portfolio_parser.add_argument("--include-outside-time-windows", action="store_true", help="Allow events outside saved preferred time windows.")
    portfolio_parser.set_defaults(func=portfolio)

    queue_parser = sub.add_parser("apply-queue", parents=[common])
    queue_parser.add_argument("--limit", type=int, default=25)
    queue_parser.set_defaults(func=apply_queue)

    live_queue_parser = sub.add_parser("live-queue", parents=[common])
    live_queue_parser.add_argument("--topics", default="AI", help="Comma-separated topic filters. Use all for no topic filter.")
    live_queue_parser.add_argument("--time-slots", default="noon,evening", help="Comma-separated time slot filters. Use all for no slot filter.")
    live_queue_parser.add_argument("--limit", type=int, default=10)
    live_queue_parser.add_argument("--include-non-partiful", action="store_true")
    live_queue_parser.add_argument("--from-cache", action="store_true", help="Use existing latest.json instead of fetching the live calendar.")
    live_queue_parser.add_argument("--first-page", action="store_true", help="When fetching live, only parse the server-embedded first page.")
    live_queue_parser.set_defaults(func=live_queue)

    day_parser = sub.add_parser("day-plan", parents=[common])
    day_parser.add_argument("date", help="Date in YYYY-MM-DD format.")
    day_parser.set_defaults(func=day_plan)

    open_parser = sub.add_parser("open", parents=[common])
    open_parser.add_argument("event_id")
    open_parser.add_argument("--no-browser", action="store_true", help="Backward-compatible no-op; open prints only by default.")
    open_parser.add_argument("--system-browser", action="store_true", help="Debug only: also open the URL with the macOS system browser.")
    open_parser.set_defaults(func=open_event)

    rsvp_context_parser = sub.add_parser("rsvp-context", parents=[common])
    rsvp_context_parser.add_argument("event_id")
    rsvp_context_parser.add_argument("--json", action="store_true")
    rsvp_context_parser.set_defaults(func=rsvp_context)

    answer_field_parser = sub.add_parser("answer-field", parents=[common])
    answer_field_parser.add_argument("event_id")
    answer_field_parser.add_argument("label")
    answer_field_parser.add_argument("--json", action="store_true")
    answer_field_parser.add_argument("--optional", action="store_true")
    answer_field_parser.add_argument("--field-type", default="text", choices=["text", "textarea", "select", "checkbox", "radio", "url", "email", "phone", "unknown"])
    answer_field_parser.add_argument("--visible-value", help="Non-sensitive value already visible in the active Partiful field.")
    answer_field_parser.add_argument("--visible-source", default="form", choices=["form", "account", "previous-response"], help="Where the visible value came from.")
    answer_field_parser.add_argument("--no-record-missing", action="store_true", help="Classify without adding needs-user-answer for unknown required fields.")
    answer_field_parser.set_defaults(func=answer_field)

    state_parser = sub.add_parser("state", parents=[common])
    state_parser.add_argument("event_id")
    state_parser.add_argument("state", choices=RSVP_STATES)
    state_parser.add_argument("--note")
    state_parser.set_defaults(func=update_state)

    profile_parser = sub.add_parser("profile", parents=[common])
    profile_sub = profile_parser.add_subparsers(dest="profile_command", required=True)
    for name in ("init", "show", "path", "missing"):
        profile_sub.add_parser(name).set_defaults(func=profile)
    profile_set_parser = profile_sub.add_parser("set")
    profile_set_parser.add_argument("field", choices=PROFILE_FIELDS)
    profile_set_parser.add_argument("value")
    profile_set_parser.set_defaults(func=profile)

    preferences_parser = sub.add_parser("preferences", parents=[common])
    preferences_sub = preferences_parser.add_subparsers(dest="preferences_command", required=True)
    for name in ("show", "path"):
        preferences_sub.add_parser(name).set_defaults(func=preferences)
    preferences_set_list_parser = preferences_sub.add_parser("set-list")
    preferences_set_list_parser.add_argument("field", choices=PREFERENCE_LIST_FIELDS)
    preferences_set_list_parser.add_argument("values", help="Comma-separated values.")
    preferences_set_list_parser.set_defaults(func=preferences)

    form_memory_parser = sub.add_parser("form-memory", parents=[common])
    form_memory_sub = form_memory_parser.add_subparsers(dest="form_memory_command", required=True)
    for name in ("show", "path"):
        form_memory_sub.add_parser(name).set_defaults(func=form_memory)
    map_parser = form_memory_sub.add_parser("map")
    map_parser.add_argument("label")
    map_parser.add_argument("profile_key", choices=PROFILE_FIELDS)
    map_parser.set_defaults(func=form_memory)
    remember_parser = form_memory_sub.add_parser("remember")
    remember_parser.add_argument("label")
    remember_parser.add_argument("value")
    remember_parser.add_argument("--event-id")
    remember_parser.add_argument("--source", choices=ANSWER_SOURCES, default="user")
    remember_parser.add_argument("--answer-class", choices=sorted(GENERATED_ANSWER_CLASSES))
    remember_parser.set_defaults(func=form_memory)
    approve_generated_parser = form_memory_sub.add_parser("approve-generated")
    approve_generated_parser.add_argument("answer_class", choices=sorted(GENERATED_ANSWER_CLASSES))
    approve_generated_parser.set_defaults(func=form_memory)
    lookup_parser = form_memory_sub.add_parser("lookup")
    lookup_parser.add_argument("label")
    lookup_parser.add_argument("--event-id")
    lookup_parser.set_defaults(func=form_memory)

    missing_fields_parser = sub.add_parser("missing-fields", parents=[common])
    missing_fields_sub = missing_fields_parser.add_subparsers(dest="missing_fields_command", required=True)
    missing_show_parser = missing_fields_sub.add_parser("show")
    missing_show_parser.add_argument("event_id", nargs="?")
    missing_show_parser.set_defaults(func=missing_fields)
    missing_add_parser = missing_fields_sub.add_parser("add")
    missing_add_parser.add_argument("event_id")
    missing_add_parser.add_argument("label")
    missing_add_parser.add_argument("--optional", action="store_true")
    missing_add_parser.add_argument("--field-type", default="text", choices=["text", "textarea", "select", "checkbox", "radio", "url", "email", "phone", "unknown"])
    missing_add_parser.add_argument("--note")
    missing_add_parser.set_defaults(func=missing_fields)
    missing_clear_parser = missing_fields_sub.add_parser("clear")
    missing_clear_parser.add_argument("event_id")
    missing_clear_parser.add_argument("--label")
    missing_clear_parser.set_defaults(func=missing_fields)
    missing_resolve_parser = missing_fields_sub.add_parser("resolve")
    missing_resolve_parser.add_argument("event_id")
    missing_resolve_parser.add_argument("label")
    missing_resolve_parser.add_argument("value")
    missing_resolve_parser.add_argument("--reusable", action="store_true", help="Save as a reusable answer instead of event-only.")
    missing_resolve_parser.add_argument("--source", choices=ANSWER_SOURCES, default="user")
    missing_resolve_parser.add_argument("--answer-class", choices=sorted(GENERATED_ANSWER_CLASSES))
    missing_resolve_parser.set_defaults(func=missing_fields)

    answers_parser = sub.add_parser("answers", parents=[common])
    answers_parser.add_argument("event_id")
    answers_parser.add_argument("--write", action="store_true")
    answers_parser.set_defaults(func=answer_sheet)

    export_parser = sub.add_parser("export", parents=[common])
    export_parser.add_argument("--format", choices=["md", "csv", "ics", "json"], default="md")
    export_parser.set_defaults(func=export_events)

    return parser


def main(argv: list[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    try:
        return int(args.func(args) or 0)
    except TechWeekError as exc:
        print(f"techweek: {exc}", file=sys.stderr)
        return 2


if __name__ == "__main__":
    raise SystemExit(main())
